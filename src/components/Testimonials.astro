---
const credentials = [
  { label: 'MNRE Registered',         detail: 'Ministry of New & Renewable Energy' },
  { label: 'ALMM-Listed Modules',     detail: 'Approved List of Models & Manufacturers' },
  { label: 'PM Surya Ghar Eligible',  detail: 'Central subsidy up to ₹78,000' },
  { label: 'DISCOM Approved',         detail: 'Net-metering & grid-tie across states' },
  { label: '25-Year O&M',             detail: 'Full lifecycle support guaranteed' },
  { label: 'Pan-India Reach',         detail: 'Projects from metros to remote sites' },
];
---

<section class="py-20 bg-brand-red">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <p class="text-white/60 text-sm font-semibold uppercase tracking-widest mb-3">Why Clients Trust Us</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Built on Credentials That Matter</h2>
      <p class="mt-4 text-white/70 max-w-2xl mx-auto">
        Every project we deliver is backed by government-aligned standards, certified equipment, and a single accountable team — from first inquiry to 25-year O&M.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {credentials.map((c) => (
        <div class="flex items-start gap-4 bg-white/10 border border-white/20 rounded-xl p-5">
          <div class="w-9 h-9 flex-shrink-0 rounded-lg bg-white/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0
                00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <p class="text-white font-semibold text-sm">{c.label}</p>
            <p class="text-white/60 text-xs mt-0.5">{c.detail}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center mt-10 text-white/50 text-sm">
      Client testimonials available on request —&nbsp;
      <a href="/contact" class="text-white underline underline-offset-2 hover:text-white/80">speak to a reference client</a>
    </p>

  </div>
</section>
