---
const solarServices = [
  { label: 'Residential Solar', href: '/services/residential' },
  { label: 'Commercial Solar', href: '/services/commercial' },
  { label: 'Industrial Solar', href: '/services/enterprise' },
  { label: 'Net Metering & Grid-Tie', href: '/services' },
  { label: 'Annual Maintenance (O&M)', href: '/services' },
];

const quickLinks = [
  { label: 'About Us', href: '/about' },
  { label: 'International Trading', href: '/portfolio' },
  { label: 'Sourcing & Procurement', href: '/products' },
  { label: 'Solar ROI Calculator', href: '/#calculator' },
  { label: 'Blog & Articles', href: '/blog' },
  { label: 'Contact Us', href: '/contact' },
];

const legal = [
  { label: 'Privacy Policy',  href: '/privacy-policy' },
  { label: 'Terms of Service', href: '/terms-of-service' },
  { label: 'Cookie Policy',   href: '/cookie-policy' },
];

const socials = [
  {
    label: 'LinkedIn',
    href: '#',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>`,
  },
  {
    label: 'Instagram',
    href: '#',
    icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
  },
  {
    label: 'YouTube',
    href: '#',
    icon: `<path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>`,
  },
  {
    label: 'X (Twitter)',
    href: '#',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    label: 'Facebook',
    href: '#',
    icon: `<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>`,
  },
];
---

<footer class="bg-neutral-ink text-white">

  <!-- Top CTA strip -->
  <div class="bg-brand-red py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xl font-bold">Ready to switch to solar?</p>
        <p class="text-white/80 text-sm mt-1">Get a free site assessment and savings estimate — no obligation.</p>
      </div>
      <a href="/get-a-quote" class="btn-ghost flex-shrink-0">
        Get a Free Quote →
      </a>
    </div>
  </div>

  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-10">

      <!-- Brand & Ratings Column (col-span-4) -->
      <div class="lg:col-span-4 flex flex-col justify-between">
        <div>
          <a href="/" aria-label="Ermis Global — Home">
            <img
              src="/logos/logo-horizontal-red.svg"
              alt="Ermis Consultants & Traders Pvt Ltd"
              class="h-10 w-auto mb-4"
              width="180" height="40"
            />
          </a>
          <p class="text-white/70 text-sm leading-relaxed mb-5 max-w-sm">
            Ermis Consultants & Traders Pvt Ltd delivers certified, high-performance solar energy systems and international procurement excellence across India.
          </p>
          
          <!-- Social links -->
          <div class="flex items-center gap-3">
            {socials.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                class="w-8 h-8 rounded-lg bg-white/5 hover:bg-brand-red flex items-center justify-center text-white/50 hover:text-white transition-all duration-200"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={s.icon} />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Google Ratings Badge -->
        <div class="mt-6 flex items-center gap-3 bg-white/5 border border-white/10 rounded-xl p-3.5 max-w-[220px]">
          <svg class="w-5 h-5 text-yellow-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <div>
            <p class="text-xs font-bold text-white leading-none">Google Rating</p>
            <p class="text-[10px] text-white/50 mt-1.5 leading-none">4.9 / 5.0 ★ (120+ reviews)</p>
          </div>
        </div>
      </div>

      <!-- Services Column (col-span-2) -->
      <div class="lg:col-span-2">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Solar Services</h3>
        <ul class="space-y-2.5">
          {solarServices.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-white/70 hover:text-brand-light transition-colors duration-150">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links Column (col-span-2) -->
      <div class="lg:col-span-2">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          {quickLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-white/70 hover:text-brand-light transition-colors duration-150">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Head Office Column (col-span-2) -->
      <div class="lg:col-span-2">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Head Office</h3>
        <div class="text-sm text-white/70 space-y-3">
          <p class="text-xs font-semibold text-white">Coimbatore</p>
          <p class="text-[11px] leading-relaxed text-white/60">
            3/73 Kurundasala Nagar,<br/>
            K. Vadamadurai, NGGO Colony,<br/>
            Kurudampalayam,<br/>
            Coimbatore – 641017
          </p>
          <div class="space-y-1.5 pt-1">
            <a href="mailto:ramc.ermis@gmail.com" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs text-brand-light">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              ramc.ermis@gmail.com
            </a>
            <a href="tel:+919894821309" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs text-brand-light">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/></svg>
              +91 98948 21309
            </a>
          </div>
        </div>
      </div>

      <!-- Branch Office Column (col-span-2) -->
      <div class="lg:col-span-2">
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Branch Office</h3>
        <div class="text-sm text-white/70 space-y-3">
          <p class="text-xs font-semibold text-white">Salem</p>
          <p class="text-[11px] leading-relaxed text-white/60">
            Authorized regional operations &amp; support desk for central Tamil Nadu solar site clearances.
          </p>
          <div class="space-y-1.5 pt-1">
            <a href="mailto:ramkumart.ermis@gmail.com" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs text-brand-light">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              ramkumart.ermis@gmail.com
            </a>
            <a href="tel:+919902257789" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs text-brand-light">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/></svg>
              +91 99022 57789
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-center sm:text-left">
      <p class="text-xs text-white/40">
        © {new Date().getFullYear()} Ermis Consultants & Traders Pvt Ltd. All rights reserved.
        CIN: U46590TZ2026OPC038272 · GST: 33AAJCE5545J1ZH
      </p>
      <div class="flex items-center gap-4">
        {legal.map((l) => (
          <a href={l.href} class="text-xs text-white/40 hover:text-white/70 transition-colors">
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </div>

</footer>
