---
const services = [
  { label: 'Solar Power Installation', href: '/services' },
  { label: 'Renewable Energy Solutions', href: '/services/commercial' },
  { label: 'International Trading',    href: '/portfolio' },
  { label: 'Sourcing & Procurement',   href: '/products' },
];

const company = [
  { label: 'About Us',     href: '/about' },
  { label: 'Our Team',     href: '/about#team' },
  { label: 'Contact Us',   href: '/contact' },
  { label: 'Get a Quote',  href: '/get-a-quote' },
];

const legal = [
  { label: 'Privacy Policy',  href: '/privacy-policy' },
  { label: 'Terms of Service', href: '/terms-of-service' },
  { label: 'Cookie Policy',   href: '/cookie-policy' },
];

const socials = [
  {
    label: 'LinkedIn',
    href: '[PLACEHOLDER — LinkedIn URL]',
    icon: `<path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>`,
  },
  {
    label: 'Instagram',
    href: '[PLACEHOLDER — Instagram URL]',
    icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
  },
  {
    label: 'YouTube',
    href: '[PLACEHOLDER — YouTube URL]',
    icon: `<path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.54C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>`,
  },
  {
    label: 'X (Twitter)',
    href: '[PLACEHOLDER — X URL]',
    icon: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
  },
  {
    label: 'Facebook',
    href: '[PLACEHOLDER — Facebook URL]',
    icon: `<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>`,
  },
];
---

<footer class="bg-neutral-ink text-white">

  <!-- Top CTA strip -->
  <div class="bg-brand-red py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xl font-bold">Ready to switch to solar?</p>
        <p class="text-white/80 text-sm mt-1">Get a free site assessment and savings estimate — no obligation.</p>
      </div>
      <a href="/get-a-quote" class="btn-ghost flex-shrink-0">
        Get a Free Quote →
      </a>
    </div>
  </div>

  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" aria-label="Ermis Global — Home">
          <img
            src="/logos/logo-horizontal-red.svg"
            alt="Ermis Consultants & Traders Pvt Ltd"
            class="h-10 w-auto mb-4"
            width="180" height="40"
          />
        </a>
        <p class="text-white/70 text-sm leading-relaxed mb-5">
          Driving sustainable energy solutions and international trade excellence since 2026.
        </p>
        <!-- Social links -->
        <div class="flex items-center gap-3 mt-5">
          {socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="text-white/50 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <Fragment set:html={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Services</h3>
        <ul class="space-y-2.5">
          {services.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-white/70 hover:text-white transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Company</h3>
        <ul class="space-y-2.5">
          {company.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-white/70 hover:text-white transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/40 mb-4">Contact</h3>
        <div class="space-y-4 text-sm text-white/70">
          <div>
            <p class="text-white font-semibold mb-1">Head Office — Coimbatore</p>
            <p class="text-xs leading-relaxed mb-1">3/73 Kurundasala Nagar, K. Vadamadurai<br/>NGGO Colony, Kurudampalayam<br/>Coimbatore – 641017</p>
            <a href="mailto:ramc.ermis@gmail.com" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs">
              <svg class="w-3.5 h-3.5 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              ramc.ermis@gmail.com
            </a>
            <a href="tel:+919894821309" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs mt-0.5">
              <svg class="w-3.5 h-3.5 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/></svg>
              +91 98948 21309 / +91 81482 21308
            </a>
          </div>
          <div>
            <p class="text-white font-semibold mb-1">Branch Office — Salem</p>
            <a href="mailto:ramkumart.ermis@gmail.com" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs">
              <svg class="w-3.5 h-3.5 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              ramkumart.ermis@gmail.com
            </a>
            <a href="tel:+919902257789" class="flex items-center gap-1.5 hover:text-white transition-colors text-xs mt-0.5">
              <svg class="w-3.5 h-3.5 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/></svg>
              +91 99022 57789
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-white/40">
        © {new Date().getFullYear()} Ermis Consultants & Traders Pvt Ltd. All rights reserved.
        CIN: U46590TZ2026OPC038272 · GST: 33AAJCE5545J1ZH
      </p>
      <div class="flex items-center gap-4">
        {legal.map((l) => (
          <a href={l.href} class="text-xs text-white/40 hover:text-white/70 transition-colors">
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </div>

</footer>
