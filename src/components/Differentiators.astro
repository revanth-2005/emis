---
const items = [
  {
    title: 'Trained & Certified Professionals',
    body:  'MNRE-certified engineers handle every project — no subcontracting, no shortcuts.',
    icon: `
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M12 14l9-5-9-5-9 5 9 5z"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M12 14l6.16-3.422A12.083 12.083 0 0121 13c0 5.523-4.03 10.092-9.316 10.932a1 1 0
           01-.368 0C6.03 23.092 2 18.523 2 13c0-.538.04-1.066.117-1.578L8 14l4 2.278L12 14z"/>
    `,
  },
  {
    title: 'Transparent Process',
    body:  'Upfront pricing, clear timelines, and no hidden charges — from survey to commissioning.',
    icon: `
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2
           M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2
           m-6 9l2 2 4-4"/>
    `,
  },
  {
    title: 'No Compromise on Quality',
    body:  'ALMM-listed panels, IEC-certified inverters, and IS 3043-compliant earthing on every system.',
    icon: `
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944
           a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9
           c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622
           0-1.042-.133-2.052-.382-3.016z"/>
    `,
  },
  {
    title: 'Assured After-Sales Service',
    body:  'Dedicated support and proactive O&M for the life of your system — not just until installation.',
    icon: `
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
        d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636
           m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
    `,
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="section-label mb-3">Our Difference</p>
      <h2 class="section-heading">What makes Ermis different?</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {items.map((item) => (
        <div class="flex flex-col">
          <!-- Icon tile -->
          <div class="w-full rounded-2xl bg-brand-pale flex items-center justify-center mb-6"
               style="aspect-ratio: 4/3;">
            <svg class="w-16 h-16 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={item.icon} />
            </svg>
          </div>
          <!-- Text -->
          <h3 class="font-extrabold text-neutral-ink text-xl mb-2 leading-snug">{item.title}</h3>
          <p class="text-base text-gray-600 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
