---
const segments = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
    image: '/service_industrial.png',
    title:    'Enterprise & Industrial',
    subtitle: 'Large-scale solar for factories, warehouses, and captive plants',
    features: [
      'Ground-mount & rooftop plants',
      'Captive power / open-access',
      'RESCO & BOOT models available',
      'DPR, EPC, and O&M services',
    ],
    href:  '/services/enterprise',
    badge: 'From 100 kW',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" points="9 22 9 12 15 12 15 22"/>`,
    image: '/service_commercial.png',
    title:    'Commercial Buildings',
    subtitle: 'Cut operational costs for offices, retail, hotels, and institutions',
    features: [
      'Rooftop net-metering systems',
      'DISCOM approval & grid-tie',
      'Subsidy & accelerated depreciation',
      'Energy-audit before proposal',
    ],
    href:  '/services/commercial',
    badge: 'From 10 kW',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1M4.22 4.22l.71.71M18.36 18.36l.71.71M1 12h1M22 12h1M4.22 19.78l.71-.71M18.36 5.64l.71-.71"/><circle cx="12" cy="12" r="5" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`,
    image: '/service_residential.png',
    title:    'Residential Homes',
    subtitle: 'Own your power — save ₹78,000+ every year on electricity',
    features: [
      'PM Surya Ghar Muft Bijli Yojana',
      '₹78,000 central subsidy eligible',
      'State DISCOM subsidy stacking',
      'Hassle-free installation in 7–14 days',
    ],
    href:  '/services/residential',
    badge: '1 kW – 10 kW',
  },
];
---

<section class="py-14 bg-neutral-snow">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-8">
      <p class="section-label mb-3">What We Do</p>
      <h2 class="section-heading">Solar Solutions for Every Scale</h2>
      <p class="mt-4 text-neutral-muted max-w-2xl mx-auto">
        Whether you run a factory, manage a commercial building, or own a home —
        Ermis Global designs and delivers the right solar system for your needs and budget.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {segments.map((seg) => (
        <div class="bg-white rounded-2xl shadow-card overflow-hidden flex flex-col group hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-neutral-rule">

          <!-- Image Container -->
          <div class="relative overflow-hidden aspect-[16/10] w-full">
            <img
              src={seg.image}
              alt={`${seg.title} project installation`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <!-- Overlay Badge -->
            <span class="absolute top-3 left-3 text-xs font-semibold text-brand-red bg-brand-pale px-3 py-1.5 rounded-full shadow-sm">
              {seg.badge}
            </span>
          </div>

          <!-- Card Content -->
          <div class="pt-10 px-6 pb-6 flex-1 flex flex-col relative">
            <!-- Overlapping Icon -->
            <div class="absolute -top-6 left-6 w-12 h-12 rounded-xl bg-white shadow-md border border-neutral-rule flex items-center justify-center z-10 group-hover:bg-brand-red transition-colors duration-300">
              <svg class="w-6 h-6 text-brand-red group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={seg.icon} />
              </svg>
            </div>

            <h3 class="text-xl font-extrabold text-neutral-ink mb-2 group-hover:text-brand-red transition-colors duration-200">{seg.title}</h3>
            <p class="text-neutral-muted text-sm mb-5 leading-relaxed">{seg.subtitle}</p>

            <ul class="space-y-2.5 mb-6 flex-1">
              {seg.features.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-neutral-ink">
                  <svg class="w-4 h-4 text-brand-red flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a href={seg.href} class="btn-outline w-full text-sm group-hover:bg-brand-red group-hover:text-white group-hover:border-brand-red transition-colors duration-200 justify-center py-3">
              Learn More →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
