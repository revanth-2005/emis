---
const reasons = [
  {
    title: 'Max Reduction in Electricity Bill',
    body:  'With the right system size, most households eliminate nearly all grid usage — and the savings start from month one.',
    icon: `<path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v6.5h5.5a1 1 0 01.82 1.573l-7 10A1 1 0 0110.5 20V13.5H5a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />`,
  },
  {
    title: 'Optimise to stay within your target tariff slab',
    body:  'Indian utilities charge progressively higher rates above consumption thresholds. Solar drops your units consumed, keeping you in a cheaper billing slab — a saving most people overlook.',
    icon: `<path fill-rule="evenodd" d="M17.707 9.293l-7-7A1 1 0 0010 2H3a1 1 0 00-1 1v7a1 1 0 00.293.707l7 7a1 1 0 001.414 0l7-7a1 1 0 000-1.414zM6 8a2 2 0 110-4 2 2 0 010 4z" clip-rule="evenodd" />`,
  },
  {
    title: 'Owning / planning to buy an EV? Prepare for real savings',
    body:  'Charging an EV can double your electricity bill overnight. A well-sized solar system offsets the cost entirely — making your EV truly free to run, for 25 years.',
    icon: `<path d="M5 4a1 1 0 00-2 0v7.268a2 2 0 000 3.464V16a1 1 0 102 0v-1.268a2 2 0 000-3.464V4zM11 4a1 1 0 10-2 0v1.268a2 2 0 000 3.464V16a1 1 0 102 0V8.732a2 2 0 000-3.464V4zM16 4a1 1 0 10-2 0v7.268a2 2 0 000 3.464V16a1 1 0 102 0v-1.268a2 2 0 000-3.464V4z" />`,
  },
];
---

<section class="py-14 bg-neutral-ink">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-start">

      <!-- Left: headline + CTA card -->
      <div class="mb-12 lg:mb-0">
        <p class="section-label mb-3 text-brand-light">Why Go Solar Now</p>
        <h2 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-6">
          Every reason<br/>to go solar —<br/>
          <span class="text-brand-light">right now.</span>
        </h2>
        <p class="text-white/80 text-base leading-relaxed mb-6">
          Solar is no longer just an environmental choice. For Indian homeowners,
          it is the most effective way to reduce costs, stay insulated from tariff
          hikes, and future-proof your home.
        </p>

        <!-- Talk to expert card -->
        <a href="/get-a-quote"
           class="flex items-center gap-5 bg-white/8 hover:bg-white/12 border border-white/15
                  rounded-2xl p-5 transition-colors duration-200 group">
          <div class="w-12 h-12 rounded-xl bg-brand-red/20 border border-brand-red/30
                      flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-brand-light" fill="currentColor" viewBox="0 0 24 24">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-white text-sm">Got questions?</p>
            <p class="text-white/50 text-xs mt-0.5">Our solar experts are just a call away.</p>
            <p class="text-brand-light text-sm font-semibold mt-1 group-hover:underline">
              Talk to an expert →
            </p>
          </div>
        </a>
      </div>

      <!-- Right: 3 reason cards -->
      <div class="space-y-5">
        {reasons.map((r) => (
          <div class="flex gap-5 bg-white/5 border border-white/10 rounded-2xl p-6
                      hover:bg-white/8 hover:border-white/20 transition-colors duration-200">
            <div class="w-12 h-12 rounded-xl bg-brand-red/20 border border-brand-red/30
                        flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-brand-light" fill="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={r.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-white text-base mb-1.5 leading-snug">{r.title}</h3>
              <p class="text-sm text-white/80 leading-relaxed">{r.body}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
