---
const stats = [
  { value: '2026',  label: 'Year Founded',              note: 'driven by a clear mission' },
  { value: '40+',   label: 'Years Combined Experience', note: 'in global trade & energy' },
  { value: '15+',   label: 'Countries Experience',      note: 'international operations' },
  { value: '100%',  label: 'Client-Focused',            note: 'your success is our measure' },
];
---

<section class="bg-brand-red">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center text-white">
      {stats.map((s) => (
        <div>
          <p class="text-3xl md:text-4xl font-extrabold animate-counter" data-value={s.value}>{s.value}</p>
          <p class="text-sm font-semibold mt-1 opacity-90">{s.label}</p>
          <p class="text-xs mt-0.5 opacity-60">{s.note}</p>
        </div>
      ))}
    </div>
  </div>
</section>
