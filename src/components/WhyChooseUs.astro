---
const stats = [
  {
    value: '150+',
    label: 'Completed Projects',
    detail: 'Rooftop & ground-mount installations delivered for homes, factories, and commercial hubs.',
  },
  {
    value: '40+',
    label: 'Years Combined Experience',
    detail: 'Our founders bring deep international expertise in global trade, industrial engineering, and solar.',
  },
  {
    value: '25',
    label: 'Year Warranty Period',
    detail: 'Linear performance warranty guaranteed on premium, MNRE-approved, and ALMM-listed modules.',
  },
  {
    value: '75+',
    label: 'Team Size',
    detail: 'Dedicated team of in-house design engineers, DISCOM liaison officers, and certified installers.',
  },
];

const reasons = [
  {
    icon: `<path fill-rule="evenodd" d="M10 2a1 1 0 00-1 .76C7.94 6.73 5.37 9.09 2 9.5a1 1 0 00-.78 1.17c1.33 5.17 5.1 8.88 8.4 9.8a1 1 0 00.74 0c3.3-.92 7.08-4.62 8.4-9.8a1 1 0 00-.8-.17c-3.37-.41-5.94-2.77-7-6.75A1 1 0 0010 2zm3 8a1 1 0 011.7-.7L12 10.59l2.29-2.29a1 1 0 111.42 1.41l-3 3a1 1 0 01-1.42 0l-1-1a1 1 0 010-1.41z" clip-rule="evenodd" />`,
    title: 'End-to-End Project Ownership',
    body: 'Site survey, system design, DISCOM approvals, installation, commissioning, and annual O&M — all under one roof.',
  },
  {
    icon: `<path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 7.5h3a1 1 0 110 2h-3v1h3a1 1 0 110 2h-3v1.5a1 1 0 11-2 0V12.5H8a1 1 0 110-2h2v-1H8a1 1 0 110-2h2V7.5H8a1 1 0 110-2h8a1 1 0 110 2h-3z" clip-rule="evenodd" />`,
    title: 'Subsidy & Financing Guidance',
    body: 'We navigate PM Surya Ghar, state DISCOM incentives, accelerated depreciation (Section 32), and solar loan options to maximise your returns.',
  },
  {
    icon: `<path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v6.5h5.5a1 1 0 01.82 1.573l-7 10A1 1 0 0110.5 20V13.5H5a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />`,
    title: 'ALMM-Listed Modules Only',
    body: 'We specify only Approved List of Models & Manufacturers (ALMM) panels — ensuring subsidy eligibility and long-term performance guarantees.',
  },
  {
    icon: `<path d="M2 10a1 1 0 011-1h3a1 1 0 110 2H3a1 1 0 01-1-1zM9 8a1 1 0 011-1h3a1 1 0 110 2h-3a1 1 0 01-1-1zM16 12a1 1 0 011-1h3a1 1 0 110 2h-3a1 1 0 01-1-1z" /><path fill-rule="evenodd" d="M4 2a2 2 0 00-2 2v12a2 2 0 002 2h2v2a1 1 0 102 0v-2h4v2a1 1 0 102 0v-2h4a2 2 0 002-2V4a2 2 0 00-2-2H4zm14 12H4V4h14v10z" clip-rule="evenodd" />`,
    title: 'Data-Driven Energy Audits',
    body: 'Every proposal starts with a detailed energy audit and shadow analysis. You get a precise ROI model with real payback period, not ballpark figures.',
  },
  {
    icon: `<path d="M9 2a1 1 0 000 2h6a1 1 0 100-2H9z" /><path fill-rule="evenodd" d="M6 5v14a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2v3a1 1 0 01-1 1H9a1 1 0 01-1-1V3a2 2 0 00-2 2zm3 9a1 1 0 011.7-.7L12 14.58l3.3-3.3a1 1 0 111.4 1.4l-4 4a1 1 0 01-1.4 0l-2-2a1 1 0 010-1.4z" clip-rule="evenodd" />`,
    title: 'MNRE-Aligned Design',
    body: 'All systems designed to Ministry of New & Renewable Energy specifications — ensuring compliance, performance, and eligibility for government incentives.',
  },
  {
    icon: `<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.514 5.731 6.97 6 7.5 6A1.5 1.5 0 019 7.5V9a1 1 0 001 1h2a1 1 0 011 1v1.5a1.5 1.5 0 01-1.5 1.5h-3A1.5 1.5 0 007 15.5v1.657a5.972 5.972 0 01-2.668-3.033 3.002 3.002 0 01.378-3.097 3.005 3.005 0 01-.378-3.00z" clip-rule="evenodd" />`,
    title: 'Pan-India Service Reach',
    body: 'With offices in Coimbatore and Salem, and partners across states, we execute projects anywhere in India — metros to remote industrial sites.',
