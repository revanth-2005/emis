                <path d="M2 10a1 1 0 011-1h3a1 1 0 110 2H3a1 1 0 01-1-1z" />
                <path fill-rule="evenodd" d="M4 2a2 2 0 00-2 2v12a2 2 0 002 2h2v2a1 1 0 102 0v-2h4v2a1 1 0 102 0v-2h4a2 2 0 002-2V4a2 2 0 00-2-2H4zm14 12H4V4h14v10z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="o-pill-label">Energy Audits</span>
          </div>
          <div class="o-tooltip">Data-Driven Energy Audits</div>
        </div>

        <!-- Outer orbit: radius 220 -->
        <div class="o-planet" data-radius="220" data-angle="120" data-period="65000"
             data-title="MNRE-Aligned Design"
             data-body="All systems designed to Ministry of New &amp; Renewable Energy specifications — ensuring compliance, performance, and eligibility for government incentives.">
          <div class="o-pill">
            <div class="o-pill-icon">
              <svg class="w-3.5 h-3.5 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 2a1 1 0 000 2h6a1 1 0 100-2H9z" />
                <path fill-rule="evenodd" d="M6 5v14a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2v3a1 1 0 01-1 1H9a1 1 0 01-1-1V3a2 2 0 00-2 2zm3 9a1 1 0 011.7-.7L12 14.58l3.3-3.3a1 1 0 111.4 1.4l-4 4a1 1 0 01-1.4 0l-2-2a1 1 0 010-1.4z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="o-pill-label">MNRE Design</span>
          </div>
          <div class="o-tooltip">MNRE-Aligned Design</div>
        </div>

        <div class="o-planet" data-radius="220" data-angle="300" data-period="65000"
             data-title="Pan-India Service Reach"
             data-body="With offices in Coimbatore and Salem, and partners across states, we execute projects anywhere in India — metros to remote industrial sites.">
          <div class="o-pill">
            <div class="o-pill-icon">
              <svg class="w-3.5 h-3.5 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.514 5.731 6.97 6 7.5 6A1.5 1.5 0 019 7.5V9a1 1 0 001 1h2a1 1 0 011 1v1.5a1.5 1.5 0 01-1.5 1.5h-3A1.5 1.5 0 007 15.5v1.657a5.972 5.972 0 01-2.668-3.033z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="o-pill-label">Pan-India Reach</span>
          </div>
          <div class="o-tooltip">Pan-India Service Reach</div>
        </div>
        <!-- (detail panel moved below orbital-wrap, see below) -->

      </div><!-- /orbital-wrap -->

      <!-- Detail panel: slides in BELOW the diagram, no overlap -->
      <div class="o-detail" id="o-detail" role="region" aria-label="Service detail">
        <div class="o-detail-card">
          <div class="o-detail-icon" id="o-detail-icon"></div>
          <div class="o-detail-text">
            <p class="o-detail-title" id="o-detail-title"></p>
            <p class="o-detail-body"  id="o-detail-body"></p>
          </div>
          <button class="o-detail-close" id="o-detail-close" aria-label="Close">&times;</button>
        </div>
      </div>

    </div><!-- /right wrapper -->

    </div>
  </div>
</section>

<script>
  // ── Intersection Observer: reveal on scroll ──────────────────────────────
  const reveal = (selector: string) => {
    const els = document.querySelectorAll<HTMLElement>(selector);
    const io = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) { (e.target as HTMLElement).classList.add('visible'); } }),
      { threshold: 0.12 }
    );
    els.forEach((el) => io.observe(el));
  };

  reveal('.stat-card');
  reveal('.reason-row');
  reveal('.left-panel');

  // ── Count-up animation ───────────────────────────────────────────────────
  const countUpObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const raw = el.dataset.target ?? '';
        // Extract the numeric part and any suffix ('+', ' Yrs', etc.)
        const match = raw.match(/^(\d+)(.*)$/);
        if (!match) return;
        const end = parseInt(match[1], 10);
        const suffix = match[2] ?? '';
        const duration = 1400;
        const start = performance.now();
        const animate = (now: number) => {
          const progress = Math.min((now - start) / duration, 1);
          // Ease out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * end) + suffix;
          if (progress < 1) requestAnimationFrame(animate);
        };
        requestAnimationFrame(animate);
        countUpObserver.unobserve(el);
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll<HTMLElement>('.js-countup').forEach((el) => {
    countUpObserver.observe(el);
  });

  // ── Orbital planet animation ─────────────────────────────────────────────
  interface PlanetConfig {
    el: HTMLElement;
    radius: number;
    angle: number;   // start angle in degrees
    period: number;  // ms for one full orbit
    startTime: number | null;
  }

  const planets: PlanetConfig[] = Array.from(
    document.querySelectorAll<HTMLElement>('.o-planet')
  ).map((el) => ({
    el,
    radius: parseFloat(el.dataset.radius ?? '100'),
    angle:  parseFloat(el.dataset.angle  ?? '0'),
    period: parseFloat(el.dataset.period ?? '40000'),
    startTime: null,
  }));

  function orbitalTick(ts: number) {
    planets.forEach((p) => {
      if (p.startTime === null) p.startTime = ts;
      const elapsed = ts - p.startTime;
      const deg = p.angle + (elapsed / p.period) * 360;
      const rad = (deg * Math.PI) / 180;
      const x = Math.cos(rad) * p.radius;
      const y = Math.sin(rad) * p.radius;
      // translate relative to center (50%,50%) of the container
      p.el.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
    });
    requestAnimationFrame(orbitalTick);
  }

  // Start orbit once diagram enters viewport
  const orbitObserver = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        requestAnimationFrame(orbitalTick);
        orbitObserver.disconnect();
      }
    },
    { threshold: 0.1 }
  );
  const diagram = document.getElementById('orbital-diagram');
  if (diagram) orbitObserver.observe(diagram);

  // ── Planet click → detail overlay ──────────────────────────────────────────
  const detail      = document.getElementById('o-detail')!;
  const detailIcon  = document.getElementById('o-detail-icon')!;
  const detailTitle = document.getElementById('o-detail-title')!;
  const detailBody  = document.getElementById('o-detail-body')!;
  const closeBtn    = document.getElementById('o-detail-close')!;

  // Icon SVG map keyed by short pill label
  const iconMap: Record<string, string> = {
    'End-to-End Project Ownership': `<svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M10 2a1 1 0 00-1 .76C7.94 6.73 5.37 9.09 2 9.5a1 1 0 00-.78 1.17c1.33 5.17 5.1 8.88 8.4 9.8a1 1 0 00.74 0c3.3-.92 7.08-4.62 8.4-9.8a1 1 0 00-.8-.17c-3.37-.41-5.94-2.77-7-6.75A1 1 0 0010 2z" clip-rule="evenodd" /></svg>`,
    'Subsidy & Financing Guidance': `<svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 7.5h3a1 1 0 110 2h-3v1h3a1 1 0 110 2h-3v1.5a1 1 0 11-2 0V12.5H8a1 1 0 110-2h2v-1H8a1 1 0 110-2h2V7.5H8a1 1 0 110-2h8a1 1 0 110 2h-3z" clip-rule="evenodd" /></svg>`,
    'ALMM-Listed Modules Only':     `<svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v6.5h5.5a1 1 0 01.82 1.573l-7 10A1 1 0 0110.5 20V13.5H5a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" /></svg>`,
    'Data-Driven Energy Audits':    `<svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path d="M2 10a1 1 0 011-1h3a1 1 0 110 2H3a1 1 0 01-1-1z"/><path fill-rule="evenodd" d="M4 2a2 2 0 00-2 2v12a2 2 0 002 2h2v2a1 1 0 102 0v-2h4v2a1 1 0 102 0v-2h4a2 2 0 002-2V4a2 2 0 00-2-2H4zm14 12H4V4h14v10z" clip-rule="evenodd"/></svg>`,
    'MNRE-Aligned Design':          `<svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path d="M9 2a1 1 0 000 2h6a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M6 5v14a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2v3a1 1 0 01-1 1H9a1 1 0 01-1-1V3a2 2 0 00-2 2zm3 9a1 1 0 011.7-.7L12 14.58l3.3-3.3a1 1 0 111.4 1.4l-4 4a1 1 0 01-1.4 0l-2-2a1 1 0 010-1.4z" clip-rule="evenodd"/></svg>`,
    'Pan-India Service Reach':      `<svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM4.332 8.027a6.012 6.012 0 011.912-2.706C6.514 5.731 6.97 6 7.5 6A1.5 1.5 0 019 7.5V9a1 1 0 001 1h2a1 1 0 011 1v1.5a1.5 1.5 0 01-1.5 1.5h-3A1.5 1.5 0 007 15.5v1.657a5.972 5.972 0 01-2.668-3.033z" clip-rule="evenodd"/></svg>`,
  };

  function openDetail(planet: HTMLElement) {
    const title = planet.dataset.title ?? '';
    const body  = planet.dataset.body  ?? '';
    detailIcon.innerHTML  = iconMap[title] ?? '';
    detailTitle.textContent = title;
    detailBody.textContent  = body;
    detail.classList.add('open');
    diagram?.classList.add('detail-open');
  }

  function closeDetail() {
    detail.classList.remove('open');
    diagram?.classList.remove('detail-open');
  }

  // Attach click listeners to each planet
  document.querySelectorAll<HTMLElement>('.o-planet').forEach((planet) => {
    planet.addEventListener('click', (e) => {
      e.stopPropagation();
      openDetail(planet);
    });
  });

  // Close on × button
  closeBtn.addEventListener('click', (e) => { e.stopPropagation(); closeDetail(); });

  // Close on backdrop click (clicking outside the card)
  detail.addEventListener('click', (e) => {
    if (e.target === detail) closeDetail();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDetail();
  });
</script>
