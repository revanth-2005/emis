---

<style>
  /* ── Floating stat card ── */
  @keyframes float-card {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }
  .float-anim {
    animation: float-card 3.2s ease-in-out infinite;
  }

  /* ── Shimmer sweep ── */
  @keyframes shimmer-sweep {
    0%   { left: -100%; }
    60%, 100% { left: 150%; }
  }
  .shimmer-text {
    position: relative;
    overflow: hidden;
    display: inline-block;
  }
  .shimmer-text::after {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.45), transparent);
    animation: shimmer-sweep 3.5s ease-in-out infinite;
    pointer-events: none;
  }

  /* ── Count-up stat cards: slide up on scroll ── */
  .stat-card {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .stat-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Reason rows: slide in from right ── */
  .reason-row {
    opacity: 0;
    transform: translateX(32px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reason-row.visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Left panel: slide up ── */
  .left-panel {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .left-panel.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Icon spin on hover ── */
  .reason-row:hover .icon-bubble {
    animation: spin-once 0.5s ease forwards;
    background-color: var(--color-brand-red, #e11d48);
  }
  .reason-row:hover .icon-bubble svg {
    color: #fff;
  }
  @keyframes spin-once {
    0%   { transform: rotate(0deg) scale(1); }
    50%  { transform: rotate(180deg) scale(1.15); }
    100% { transform: rotate(360deg) scale(1); }
  }

  /* ── Red highlight bar on hover ── */
  .reason-row {
    position: relative;
    padding-left: 0;
    border-radius: 10px;
    padding: 10px 10px 10px 14px;
    transition: background 0.25s ease, opacity 0.5s ease, transform 0.5s ease;
  }
  .reason-row::before {
    content: '';
    position: absolute;
    left: 0; top: 12%; bottom: 12%;
    width: 3px;
    border-radius: 4px;
    background: var(--color-brand-red, #e11d48);
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }
  .reason-row:hover::before {
    transform: scaleY(1);
  }
  .reason-row:hover {
    background: #fff5f5;
  }
  .reason-row:hover h3 {
    color: var(--color-brand-red, #e11d48);
  }

  /* ══ Orbital Diagram ══════════════════════════════════════════════════ */
  .orbital-wrap {
    position: relative;
    width: 100%;
    max-width: 480px;
    height: 480px;
    margin: 0 auto;
  }

  /* Dashed orbit rings */
  .o-ring {
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    border: 1.5px dashed rgba(225,29,72,0.22);
    transform: translate(-50%,-50%);
    pointer-events: none;
  }
  @keyframes ring-cw  { to { transform: translate(-50%,-50%) rotate( 360deg); } }
  @keyframes ring-ccw { to { transform: translate(-50%,-50%) rotate(-360deg); } }
  .o-ring-1 { width:180px; height:180px; animation: ring-cw  28s linear infinite; }
  .o-ring-2 { width:310px; height:310px; animation: ring-ccw 45s linear infinite; }
  .o-ring-3 { width:440px; height:440px; animation: ring-cw  65s linear infinite; }

  /* Central hub */
  .o-hub {
    position: absolute;
    top:50%; left:50%;
    transform: translate(-50%,-50%);
    width: 84px; height: 84px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 8px rgba(225,29,72,0.08), 0 6px 24px rgba(225,29,72,0.18);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    z-index: 20;
  }
  @keyframes hub-pulse {
    0%,100% { box-shadow: 0 0 0 8px rgba(225,29,72,0.08), 0 6px 24px rgba(225,29,72,0.18); }
    50%      { box-shadow: 0 0 0 14px rgba(225,29,72,0.13), 0 8px 32px rgba(225,29,72,0.30); }
  }
  .o-hub { animation: hub-pulse 2.8s ease-in-out infinite; }

  /* Planet pills */
  .o-planet {
    position: absolute;
    top: 50%; left: 50%;
    z-index: 10;
    pointer-events: auto;
  }
  .o-pill {
    transform: translate(-50%, -50%);
    display: flex; align-items: center; gap: 7px;
    background: #fff;
    border: 1px solid rgba(225,29,72,0.15);
    border-radius: 40px;
    padding: 6px 12px 6px 8px;
    box-shadow: 0 3px 14px rgba(0,0,0,0.10);
    white-space: nowrap;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    user-select: none;
  }
  .o-pill:hover {
    transform: translate(-50%,-50%) scale(1.08);
    box-shadow: 0 6px 22px rgba(225,29,72,0.22);
    border-color: rgba(225,29,72,0.4);
  }
  .o-pill-icon {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: rgba(225,29,72,0.1);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .o-pill-label {
    font-size: 11px;
    font-weight: 700;
    color: #1a1a1a;
    letter-spacing: -0.01em;
  }
  /* Tooltip on hover */
  .o-planet { position: absolute; }
  .o-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    color: #fff;
    font-size: 10px;
    line-height: 1.4;
    padding: 5px 9px;
    border-radius: 6px;
    white-space: nowrap;
    max-width: 180px;
    white-space: normal;
    text-align: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 30;
  }
  .o-tooltip::after {
    content: '';
    position: absolute;
    top: 100%; left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: #1a1a1a;
  }
  .o-pill:hover + .o-tooltip,
  .o-planet:hover .o-tooltip { opacity: 1; }

  /* ══ Detail panel (below the diagram, no overlap) ══════════════════════ */
  .o-detail {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-10px);
    transition: opacity 0.35s ease, max-height 0.45s ease, transform 0.35s ease, margin-top 0.35s ease;
    margin-top: 0;
  }
  .o-detail.open {
    opacity: 1;
    max-height: 320px;
    pointer-events: auto;
    transform: translateY(0);
    margin-top: 16px;
  }
  .o-detail-card {
    background: #fff;
    border-radius: 18px;
    padding: 22px 20px 20px;
    box-shadow: 0 8px 40px rgba(225,29,72,0.12), 0 2px 12px rgba(0,0,0,0.07);
    border: 1px solid rgba(225,29,72,0.14);
    width: 100%;
    position: relative;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .o-detail-close {
    position: absolute;
    top: 10px; right: 12px;
    width: 26px; height: 26px;
    border-radius: 50%;
    border: none;
    background: rgba(225,29,72,0.08);
    color: #e11d48;
    font-size: 15px;
    line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }
  .o-detail-close:hover { background: rgba(225,29,72,0.18); }
  .o-detail-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    background: rgba(225,29,72,0.1);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .o-detail-text { flex: 1; padding-right: 24px; }
  .o-detail-title {
    font-size: 14px;
    font-weight: 800;
    color: #111;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .o-detail-body {
    font-size: 12px;
    color: #555;
    line-height: 1.7;
  }
  /* hide tooltip while detail is open */
  .orbital-wrap.detail-open .o-tooltip { display: none; }
</style>

<!-- Why Choose Section: stat cards -->
<section class="py-14 bg-neutral-snow">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <p class="section-label mb-3">Why Choose Ermis</p>
      <h2 class="section-heading">Experience, Expertise &amp; Commitment to Excellence</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {stats.map((s, i) => (
        <div
          class="stat-card bg-white rounded-2xl border border-neutral-rule shadow-card p-6 text-center hover:shadow-lg transition-shadow duration-200 flex flex-col justify-between"
          style={`transition-delay: ${i * 100}ms`}
        >
          <div>
            <p
              class="text-4xl sm:text-5xl font-black text-brand-red mb-3 tracking-tight js-countup"
              data-target={s.value}
            >
              {s.value}
            </p>
            <h3 class="font-bold text-neutral-ink text-base mb-2">{s.label}</h3>
            <p class="text-xs text-neutral-muted leading-relaxed">{s.detail}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- Detailed Reasons -->
<section class="py-14 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 lg:items-start">

      <!-- Left sticky panel -->
      <div class="left-panel mb-8 lg:mb-0 lg:sticky lg:top-24">
        <p class="section-label mb-3">Our Promise</p>
        <h2 class="section-heading mb-5">
          Solar Made Simple,<br/>Savings Made Real
        </h2>
        <p class="text-neutral-muted leading-relaxed mb-6">
          We founded Ermis to fix what's broken in India's solar market — bad information,
          opaque pricing, and vendors who disappear after installation. Our team's international
          track record means you get global standards delivered locally.
        </p>
        <a href="/about" class="btn-outline inline-flex">
          Our Story →
        </a>

        <!-- Floating payback card with shimmer -->
        <div class="float-anim mt-10 rounded-2xl bg-brand-pale border border-brand-red/20 p-6 shadow-md">
          <p class="shimmer-text text-4xl font-extrabold text-brand-red">&lt; 7 yrs</p>
          <p class="text-sm font-semibold text-neutral-ink mt-1">Typical payback period</p>
          <p class="text-xs text-neutral-muted mt-1">for a commercial rooftop installation*</p>
          <p class="text-xs text-neutral-muted mt-4">*Indicative. Actual payback depends on system size, local tariff, and available subsidies.</p>
        </div>
      </div>

      <!-- Right: Orbital + Detail panel -->
      <div>
      <div class="orbital-wrap" id="orbital-diagram" aria-label="Ermis Solar Service Ecosystem">

        <!-- Orbit rings (visual decoration) -->
        <div class="o-ring o-ring-1"></div>
        <div class="o-ring o-ring-2"></div>
        <div class="o-ring o-ring-3"></div>

        <!-- Central hub -->
        <div class="o-hub">
          <svg class="w-6 h-6 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v6.5h5.5a1 1 0 01.82 1.573l-7 10A1 1 0 0110.5 20V13.5H5a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          <span class="text-[10px] font-black text-neutral-ink tracking-tight mt-0.5">ERMIS</span>
        </div>

        <!-- Planets (JS positions these) -->
        <!-- Inner orbit: radius 90 -->
        <div class="o-planet" data-radius="90" data-angle="0" data-period="28000"
             data-title="End-to-End Project Ownership"
             data-body="Site survey, system design, DISCOM approvals, installation, commissioning, and annual O&amp;M — all under one roof.">
          <div class="o-pill">
            <div class="o-pill-icon">
              <svg class="w-3.5 h-3.5 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M10 2a1 1 0 00-1 .76C7.94 6.73 5.37 9.09 2 9.5a1 1 0 00-.78 1.17c1.33 5.17 5.1 8.88 8.4 9.8a1 1 0 00.74 0c3.3-.92 7.08-4.62 8.4-9.8a1 1 0 00-.8-.17c-3.37-.41-5.94-2.77-7-6.75A1 1 0 0010 2z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="o-pill-label">End-to-End</span>
          </div>
          <div class="o-tooltip">End-to-End Project Ownership</div>
        </div>

        <div class="o-planet" data-radius="90" data-angle="180" data-period="28000"
             data-title="Subsidy &amp; Financing Guidance"
             data-body="We navigate PM Surya Ghar, state DISCOM incentives, accelerated depreciation (Section 32), and solar loan options to maximise your returns.">
          <div class="o-pill">
            <div class="o-pill-icon">
              <svg class="w-3.5 h-3.5 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 7.5h3a1 1 0 110 2h-3v1h3a1 1 0 110 2h-3v1.5a1 1 0 11-2 0V12.5H8a1 1 0 110-2h2v-1H8a1 1 0 110-2h2V7.5H8a1 1 0 110-2h8a1 1 0 110 2h-3z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="o-pill-label">Subsidy Guide</span>
          </div>
          <div class="o-tooltip">Subsidy &amp; Financing Guidance</div>
        </div>

        <!-- Middle orbit: radius 155 -->
        <div class="o-planet" data-radius="155" data-angle="60" data-period="45000"
             data-title="ALMM-Listed Modules Only"
             data-body="We specify only Approved List of Models &amp; Manufacturers (ALMM) panels — ensuring subsidy eligibility and long-term performance guarantees.">
          <div class="o-pill">
            <div class="o-pill-icon">
              <svg class="w-3.5 h-3.5 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v6.5h5.5a1 1 0 01.82 1.573l-7 10A1 1 0 0110.5 20V13.5H5a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="o-pill-label">ALMM Modules</span>
          </div>
          <div class="o-tooltip">ALMM-Listed Modules Only</div>
        </div>

        <div class="o-planet" data-radius="155" data-angle="240" data-period="45000"
             data-title="Data-Driven Energy Audits"
             data-body="Every proposal starts with a detailed energy audit and shadow analysis. You get a precise ROI model with real payback period, not ballpark figures.">
