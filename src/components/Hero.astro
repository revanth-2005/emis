---
export interface Props {
  headline:    string;
  subheadline: string;
  ctaPrimary:  { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  badge?:      string;
}

const {
  headline,
  subheadline,
  ctaPrimary,
  ctaSecondary,
  badge,
} = Astro.props;
---

<section class="relative bg-neutral-ink overflow-hidden py-16 lg:py-24 flex items-center min-h-[calc(100vh-80px)]">
  <!-- Visual Storytelling background image slider with dark overlay -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <div class="hero-slide absolute inset-0 bg-[url('/hero_solar_installation.png')] bg-cover bg-center bg-no-repeat opacity-100 transition-opacity duration-1000"></div>
    <div class="hero-slide absolute inset-0 bg-[url('/gallery_commercial.png')] bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"></div>
    <div class="hero-slide absolute inset-0 bg-[url('/gallery_industrial.png')] bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"></div>
    <div class="hero-slide absolute inset-0 bg-[url('/gallery_residential.png')] bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"></div>
    <div class="hero-slide absolute inset-0 bg-[url('/service_commercial.png')] bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"></div>
  </div>
  <div class="absolute inset-0 bg-neutral-ink/80 z-1" aria-hidden="true"></div>

  <!-- Bottom fade to next section -->
  <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none bg-gradient-to-t from-neutral-ink to-transparent z-2"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      
      <!-- Left: hero copy -->
      <div class="lg:col-span-7 flex flex-col justify-center text-left">
        {badge && (
          <div class="animate-stagger-item" style="animation-delay: 100ms;">
            <span class="inline-flex items-center gap-2 mb-6 px-3.5 py-1.5 rounded-full text-xs font-semibold
                         bg-brand-red/20 text-brand-light border border-brand-red/30 self-start">
              <span class="w-1.5 h-1.5 rounded-full bg-brand-light animate-pulse"></span>
              {badge}
            </span>
          </div>
        )}
        
        <div class="animate-stagger-item" style="animation-delay: 200ms;">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
            {headline}
          </h1>
        </div>

        <div class="animate-stagger-item" style="animation-delay: 300ms;">
          <p class="text-lg text-white/70 leading-relaxed mb-8">
            {subheadline}
          </p>
        </div>

        <!-- Feature Points List -->
        <div class="animate-stagger-item mb-8" style="animation-delay: 400ms;">
          <ul class="space-y-3 text-white/90">
            {[
              'Save Up to 90% on Electricity Bills',
              'MNRE-aligned solutions',
              'Net-metering & PM Surya Ghar eligible',
              'ALMM-listed modules'
            ].map((point) => (
              <li class="flex items-center gap-3 text-sm sm:text-base font-semibold">
                <span class="w-5 h-5 rounded-full bg-brand-red flex items-center justify-center text-white flex-shrink-0 text-xs font-bold shadow-sm">
                  ✓
                </span>
                {point}
              </li>
            ))}
          </ul>
        </div>

        <div class="animate-stagger-item" style="animation-delay: 500ms;">
          <div class="flex flex-col sm:flex-row gap-4 mb-8 lg:mb-0">
            <a href={ctaPrimary.href}
               class="inline-flex items-center justify-center gap-2 bg-brand-red text-white font-semibold
                      text-base px-8 py-4 rounded-lg shadow-cta hover:bg-brand-dark transition-colors duration-200 text-center">
              {ctaPrimary.label}
            </a>
            {ctaSecondary && (
              <a href={ctaSecondary.href}
                 class="inline-flex items-center justify-center gap-2 font-semibold text-base
                        px-8 py-4 rounded-lg border-2 border-white/50 text-white
                        hover:border-white hover:bg-white/10 transition-colors duration-200 text-center">
                {ctaSecondary.label}
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Right: floating consultation form card -->
      <div class="lg:col-span-5 flex flex-col justify-center relative z-10 w-full max-w-md mx-auto lg:max-w-none">
        <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 w-full">
          <div id="hero-form-wrap" class="flex flex-col">
            <div class="animate-stagger-item" style="animation-delay: 100ms;">
              <p class="text-2xl font-extrabold text-neutral-ink leading-snug mb-1">
                Book a <span class="text-brand-red">FREE</span> Consultation
              </p>
              <p class="text-sm text-neutral-muted mb-6">Save up to ₹78,000 on residential solar with central subsidy</p>
            </div>

            <form
              id="hero-lead-form"
              name="hero-lead"
              method="POST"
              data-netlify="true"
              data-netlify-honeypot="bot-field"
              class="flex flex-col space-y-3"
            >
              <input type="hidden" name="form-name" value="hero-lead" />
              <p class="hidden"><input name="bot-field" /></p>

              <div class="animate-stagger-item" style="animation-delay: 200ms;">
                <input name="name" type="text" required placeholder="Full Name" class="hero-input w-full" />
              </div>
              
              <div class="animate-stagger-item" style="animation-delay: 300ms;">
                <input name="phone" type="tel" required placeholder="Mobile Number"
                  pattern="[6-9][0-9]{9}" title="Enter a valid 10-digit Indian mobile number"
                  class="hero-input w-full" />
              </div>

              <div class="animate-stagger-item" style="animation-delay: 400ms;">
                <input name="pincode" type="text" required placeholder="PIN Code"
                  pattern="[1-9][0-9]{5}" title="Enter a valid 6-digit PIN code"
                  maxlength="6" class="hero-input w-full" />
              </div>

              <div class="animate-stagger-item" style="animation-delay: 500ms;">
                <label for="monthly_bill" class="block text-sm font-bold text-neutral-ink mb-1.5">Monthly Electricity Bill</label>
                <div class="relative">
                  <select
                    id="monthly_bill"
                    name="monthly_bill"
                    required
                    class="w-full px-4 py-3 pr-10 border border-neutral-rule rounded-xl text-base font-semibold text-neutral-muted outline-none focus:ring-2 focus:ring-brand-red bg-neutral-snow focus:text-neutral-ink cursor-pointer appearance-none"
                  >
                    <option value="" disabled selected>Select your monthly bill</option>
                    <option value="<1500">Less than ₹1,500</option>
                    <option value="1500-2500">₹1,500 – ₹2,500</option>
                    <option value="2500-4000">₹2,500 – ₹4,000</option>
                    <option value="4000-8000">₹4,000 – ₹8,000</option>
                    <option value=">8000">More than ₹8,000</option>
                  </select>
                  <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-neutral-muted">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </div>
                </div>
              </div>

              <div class="animate-stagger-item" style="animation-delay: 600ms;">
                <label class="flex items-start gap-2 cursor-pointer pt-1">
                  <input type="checkbox" name="consent" required
                    class="mt-0.5 w-4 h-4 flex-shrink-0 accent-brand-red" />
                  <span class="text-xs text-neutral-muted leading-snug">
                    I agree to Ermis Global's
                    <a href="/terms-of-service" class="text-brand-red hover:underline" target="_blank">Terms</a>
                    and
                    <a href="/privacy-policy" class="text-brand-red hover:underline" target="_blank">Privacy</a>.
                  </span>
                </label>
              </div>

              <div class="animate-stagger-item pt-2" style="animation-delay: 700ms;">
                <button type="submit"
                  class="w-full bg-brand-red text-white font-extrabold text-base py-4 rounded-xl
                         hover:bg-brand-dark transition-colors duration-200 shadow-cta">
                  Book My FREE Consultation →
                </button>
                <p class="text-xs text-center text-neutral-muted mt-2">Free, no obligation. We respond within 1 business day.</p>
              </div>
            </form>
          </div>

          <!-- Success state -->
          <div id="hero-form-success" class="hidden flex flex-col items-center justify-center text-center py-8">
            <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <p class="text-2xl font-extrabold text-neutral-ink mb-2">You're booked!</p>
            <p class="text-base text-neutral-muted leading-relaxed">
              Our solar expert will call you within 1 business day to schedule your free consultation.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-input {
    @apply w-full px-4 py-3 border border-neutral-rule rounded-xl text-base font-medium
           focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none
           bg-neutral-snow text-neutral-ink placeholder-neutral-muted;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-stagger-item {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    will-change: transform, opacity;
  }
</style>

<script>
  const form = document.getElementById('hero-lead-form') as HTMLFormElement | null;
  const wrap = document.getElementById('hero-form-wrap');
  const success = document.getElementById('hero-form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new URLSearchParams(new FormData(form) as any);
    try {
      await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: data.toString() });
    } catch (_) {}
    wrap?.classList.add('hidden');
    success?.classList.remove('hidden');
  });

  // Hero Background Slider
  const slides = document.querySelectorAll('.hero-slide');
  let currentSlide = 0;

  if (slides.length > 1) {
    // Preload other slider images to prevent download delay on first cycle
    const preloadImages = [
      '/gallery_commercial.png',
      '/gallery_industrial.png',
      '/gallery_residential.png',
      '/service_commercial.png'
    ];
    preloadImages.forEach((src) => {
      const img = new Image();
      img.src = src;
    });

    setInterval(() => {
      slides[currentSlide].classList.remove('opacity-100');
      slides[currentSlide].classList.add('opacity-0');
      
      currentSlide = (currentSlide + 1) % slides.length;
      
      slides[currentSlide].classList.remove('opacity-0');
      slides[currentSlide].classList.add('opacity-100');
    }, 2500); // Expose each slide for 2.5 seconds
  }
</script>
