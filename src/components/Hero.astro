---
export interface Props {
  headline:    string;
  subheadline: string;
  ctaPrimary:  { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  badge?:      string;
}

const {
  headline,
  subheadline,
  ctaPrimary,
  ctaSecondary,
  badge,
} = Astro.props;
---

<section class="relative bg-neutral-ink overflow-hidden">
  <!-- Solar panel pattern — panel module borders (120×80px) -->
  <div class="absolute inset-0 pointer-events-none"
       style="background-image: linear-gradient(rgba(196,59,49,0.22) 1.5px, transparent 1.5px), linear-gradient(90deg, rgba(196,59,49,0.22) 1.5px, transparent 1.5px); background-size: 120px 80px, 120px 80px;">
  </div>
  <!-- Solar panel pattern — cell subdivision (24×20px = 5×4 cells per module) -->
  <div class="absolute inset-0 pointer-events-none"
       style="background-image: linear-gradient(rgba(196,59,49,0.09) 0.5px, transparent 0.5px), linear-gradient(90deg, rgba(196,59,49,0.09) 0.5px, transparent 0.5px); background-size: 24px 20px, 24px 20px;">
  </div>
  <!-- Red glow — full-width radial so there's no hard edge -->
  <div class="absolute inset-0 pointer-events-none"
       style="background: radial-gradient(ellipse 70% 80% at 85% 30%, rgba(196,59,49,0.35) 0%, rgba(196,59,49,0.12) 45%, transparent 75%)">
  </div>
  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-neutral-ink to-transparent pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 lg:py-24">
    <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div>
        {badge && (
          <span class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full text-xs font-semibold
                       bg-brand-red/20 text-brand-light border border-brand-red/30">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-light animate-pulse"></span>
            {badge}
          </span>
        )}

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          {headline}
        </h1>

        <p class="text-lg md:text-xl text-white/70 leading-relaxed mb-10">
          {subheadline}
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href={ctaPrimary.href}
             class="inline-flex items-center justify-center gap-2 bg-brand-red text-white font-semibold
                    text-base px-8 py-4 rounded-lg shadow-cta hover:bg-brand-dark transition-colors duration-200">
            {ctaPrimary.label}
          </a>
          {ctaSecondary && (
            <a href={ctaSecondary.href}
               class="inline-flex items-center justify-center gap-2 font-semibold text-base
                      px-8 py-4 rounded-lg border-2 border-white/50 text-white
                      hover:border-white hover:bg-white/10 transition-colors duration-200">
              {ctaSecondary.label}
            </a>
          )}
        </div>

        <!-- Trust signals -->
        <div class="mt-10 flex flex-wrap items-center gap-5 text-sm text-white/50">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-light flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0
                00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414
                0l4-4z" clip-rule="evenodd"/>
            </svg>
            MNRE-aligned solutions
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-light flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0
                00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414
                0l4-4z" clip-rule="evenodd"/>
            </svg>
            Net-metering & PM Surya Ghar eligible
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-light flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0
                00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414
                0l4-4z" clip-rule="evenodd"/>
            </svg>
            ALMM-listed modules
          </span>
        </div>
      </div>

      <!-- Right: metrics card (desktop only) -->
      <div class="hidden lg:block">
        <div class="relative">
          <!-- Glow blobs -->
          <div class="absolute -top-8 -right-8 w-40 h-40 bg-brand-red/20 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-brand-red/10 rounded-full blur-3xl"></div>

          <div class="relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-light mb-6">Why Go Solar Now</p>

            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-xl bg-brand-red/15 border border-brand-red/25 p-5 text-center">
                <div class="text-4xl font-extrabold text-white">90%</div>
                <div class="text-xs text-white/60 mt-1.5 leading-snug">Electricity bill<br/>reduction</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-5 text-center">
                <div class="text-4xl font-extrabold text-white">25yr</div>
                <div class="text-xs text-white/60 mt-1.5 leading-snug">O&M warranty<br/>coverage</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-5 text-center">
                <div class="text-4xl font-extrabold text-white">14d</div>
                <div class="text-xs text-white/60 mt-1.5 leading-snug">Average residential<br/>install time</div>
              </div>
              <div class="rounded-xl bg-white/5 border border-white/10 p-5 text-center">
                <div class="text-4xl font-extrabold text-white">₹0</div>
                <div class="text-xs text-white/60 mt-1.5 leading-snug">Site assessment<br/>cost</div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>
