---

<section class="py-20 bg-neutral-snow">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">
      
      <!-- Left Column: Sticky Title and CTA -->
      <div class="lg:col-span-5 lg:sticky lg:top-32 text-center lg:text-left z-20">
        <p class="section-label mb-3">The Process</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-neutral-ink leading-tight">
          From Inquiry to Bill Savings<br class="hidden lg:block"/> Here's How It Works
        </h2>
        <p class="text-base sm:text-lg text-neutral-muted mt-5 leading-relaxed max-w-xl mx-auto lg:mx-0">
          We guide you step-by-step through structural design, net-metering approvals, professional installation, and final savings activation.
        </p>
        <div class="mt-8 hidden lg:block">
          <a href="/get-a-quote" class="btn-primary inline-flex">
            Start with a Free Assessment
          </a>
        </div>
      </div>

      <!-- Right Column: Sticky Stack Cards -->
      <div class="lg:col-span-7 relative" id="sticky-process-stack" style="padding-bottom: 2rem;">
        {steps.map((step, i) => (
          <div class="process-card md:sticky bg-white rounded-3xl border border-neutral-rule/60 shadow-card p-6 md:p-8 flex flex-col sm:flex-row items-center sm:items-start gap-6 mb-6"
               style={`top: 120px; z-index: ${i + 1};`}>
            
            <!-- Icon bubble with corner index tag -->
            <div class="relative flex-shrink-0">
              <div class="w-16 h-16 rounded-2xl bg-brand-pale border-2 border-brand-red/10 flex items-center justify-center shadow-sm">
                {step.image ? (
                  <img src={step.image} alt={step.title} class="w-10 h-10 object-contain rounded-md orange-icon-filter" />
                ) : (
                  <svg class="w-8 h-8 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={step.icon} />
                  </svg>
                )}
              </div>
              <span class="absolute -top-1.5 -right-1.5 bg-neutral-ink text-white text-[10px] font-black w-6 h-6 rounded-full flex items-center justify-center border border-white shadow-sm">
                {step.num}
              </span>
            </div>

            <!-- Title & Body -->
            <div class="flex-grow text-center sm:text-left">
              <h3 class="font-medium text-neutral-ink mb-2 text-xl leading-snug">{step.title}</h3>
              <p class="text-sm md:text-base text-neutral-muted leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Mobile Button -->
    <div class="text-center mt-12 lg:hidden">
      <a href="/get-a-quote" class="btn-primary inline-flex">
        Start with a Free Assessment
      </a>
    </div>
  </div>
</section>

<script>
  function initStickyStack() {
    const cards = Array.from(document.querySelectorAll('.process-card')) as HTMLElement[];
    if (cards.length === 0) return;
    const CARD_TOP = 120;

    const onScroll = () => {
      if (window.innerWidth < 1024) {
        cards.forEach((card) => {
          card.style.transform = '';
          card.style.opacity = '';
          card.style.filter = '';
        });
        return;
      }

      cards.forEach((card, idx) => {
        // Count how many later cards are already stacked at/above the sticky position
        let behindAmount = 0;

        for (let j = idx + 1; j < cards.length; j++) {
          const laterRect = cards[j].getBoundingClientRect();
          if (laterRect.top <= CARD_TOP + 2) {
            behindAmount += 1;
          } else {
            const partial = Math.max(0, Math.min(1, (CARD_TOP + 100 - laterRect.top) / 100));
            behindAmount += partial;
            break;
          }
        }

        if (behindAmount > 0) {
          const scale = Math.max(0.88, 1 - behindAmount * 0.035);
          const translateY = -behindAmount * 10;
          const opacity = Math.max(0.4, 1 - behindAmount * 0.18);
          card.style.transform = `scale(${scale}) translateY(${translateY}px)`;
          card.style.opacity = String(opacity);
          card.style.filter = `blur(${Math.min(behindAmount * 0.4, 1.5)}px)`;
        } else {
          card.style.transform = 'scale(1) translateY(0)';
          card.style.opacity = '1';
          card.style.filter = 'none';
        }
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  }

  document.addEventListener('DOMContentLoaded', initStickyStack);
  document.addEventListener('astro:page-load', initStickyStack);
  initStickyStack();
</script>

<style>
  .orange-icon-filter {
    filter: brightness(1.3) contrast(1.4) invert(34%) sepia(85%) saturate(2200%) hue-rotate(345deg) brightness(72%) contrast(95%);
    mix-blend-mode: multiply;
  }

  #sticky-process-stack .process-card {
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease, filter 0.35s ease;
    will-change: transform, opacity;
  }

  @media (min-width: 1024px) {
    #sticky-process-stack .process-card {
      position: sticky !important;
    }
  }
</style>
