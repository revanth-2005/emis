---

<section class="py-20 bg-neutral-snow">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">
      
      <!-- Left Column: Sticky Title and CTA -->
      <div class="lg:col-span-5 lg:sticky lg:top-32 text-center lg:text-left z-20">
        <p class="section-label mb-3">The Process</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-neutral-ink leading-tight">
          From Inquiry to Bill Savings<br class="hidden lg:block"/> — Here's How It Works
        </h2>
        <p class="text-base sm:text-lg text-neutral-muted mt-5 leading-relaxed max-w-xl mx-auto lg:mx-0">
          We guide you step-by-step through structural design, net-metering approvals, professional installation, and final savings activation.
        </p>
        <div class="mt-8 hidden lg:block">
          <a href="/get-a-quote" class="btn-primary inline-flex">
            Start with a Free Assessment
          </a>
        </div>
      </div>

      <!-- Right Column: Sticky Stack Cards -->
      <div class="lg:col-span-7 relative flex flex-col gap-6" id="sticky-process-stack">
        {steps.map((step, i) => (
          <div class="process-card md:sticky bg-white rounded-3xl border border-neutral-rule/60 shadow-card p-6 md:p-8 flex flex-col sm:flex-row items-center sm:items-start gap-6 transition-all duration-500 ease-out origin-top z-10"
               style={`top: ${120 + i * 24}px; z-index: ${i + 1};`}>
            
            <!-- Icon bubble with corner index tag -->
            <div class="relative flex-shrink-0">
              <div class="w-16 h-16 rounded-2xl bg-brand-pale border-2 border-brand-red/10 flex items-center justify-center shadow-sm">
                <svg class="w-8 h-8 text-brand-red" fill="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={step.icon} />
                </svg>
              </div>
              <span class="absolute -top-1.5 -right-1.5 bg-neutral-ink text-white text-[10px] font-black w-6 h-6 rounded-full flex items-center justify-center border border-white shadow-sm">
                {step.num}
              </span>
            </div>

            <!-- Title & Body -->
            <div class="flex-grow text-center sm:text-left">
              <h3 class="font-extrabold text-neutral-ink mb-2 text-xl leading-snug">{step.title}</h3>
              <p class="text-sm md:text-base text-neutral-muted leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Mobile Button -->
    <div class="text-center mt-12 lg:hidden">
      <a href="/get-a-quote" class="btn-primary inline-flex">
        Start with a Free Assessment
      </a>
    </div>
  </div>
</section>

<script>
  function initStickyStack() {
    const cards = document.querySelectorAll('.process-card') as NodeListOf<HTMLElement>;
    const container = document.getElementById('sticky-process-stack');
    
    if (cards.length === 0 || !container) return;

    const handleScroll = () => {
      if (window.innerWidth < 768) {
        // Reset styles on mobile to prevent overlapping issues
        cards.forEach((card) => {
          card.style.transform = '';
          card.style.opacity = '';
          card.style.filter = '';
        });
        return;
      }

      cards.forEach((card, idx) => {
        const nextCard = cards[idx + 1];
        if (nextCard) {
          const nextCardRect = nextCard.getBoundingClientRect();
          // The sticky top position for the next card (must match top style)
          const stickyThreshold = 120 + (idx + 1) * 24;
          
          if (nextCardRect.top <= stickyThreshold + 100) {
            // Next card is close or overlapping. Scale down and fade this card.
            const overlapAmount = Math.max(0, Math.min(1, (stickyThreshold + 100 - nextCardRect.top) / 200));
            const scale = 1 - overlapAmount * 0.04;
            const opacity = 1 - overlapAmount * 0.35;
            const translate = -overlapAmount * 12;
            
            card.style.transform = `scale(${scale}) translateY(${translate}px)`;
            card.style.opacity = `${opacity}`;
            card.style.filter = `blur(${overlapAmount * 0.5}px)`;
          } else {
            card.style.transform = 'scale(1) translateY(0)';
            card.style.opacity = '1';
            card.style.filter = 'none';
          }
        }
      });
    };

    window.addEventListener('scroll', handleScroll);
    window.addEventListener('resize', handleScroll);
    
    // Initial run
    handleScroll();
  }

  // Set up on page load
  document.addEventListener('DOMContentLoaded', initStickyStack);
</script>
