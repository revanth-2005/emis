---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  schema?: object;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonicalURL = Astro.url.href,
  schema,
} = Astro.props;

const siteName   = 'Ermis Global — Solar Energy Solutions';
const fullTitle  = title.includes('Ermis') ? title : `${title} | Ermis Global`;
---
<!doctype html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#C43B31" />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(image, Astro.site).toString()} />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:locale"      content="en_IN" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(image, Astro.site).toString()} />

  <!-- Favicons -->
  <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180"      href="/apple-touch-icon.png" />

  <!-- Metropolis font is self-hosted in /public/fonts/ via global.css -->

  <!-- JSON-LD Structured Data -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Default LocalBusiness schema on every page -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Ermis Consultants & Traders Pvt Ltd",
    "alternateName": "Ermis Global",
    "url": "https://ermisglobal.com",
    "logo": "https://ermisglobal.com/logos/logo-horizontal-red.svg",
    "description": "India's trusted solar energy consultants — rooftop, commercial, and industrial solar solutions with end-to-end project delivery.",
    "telephone": "+91-98948-21309",
    "email": "ramc.ermis@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "3/73, Kurundasala Nagar, K. Vadamadurai, NGGO Colony",
      "addressLocality": "Kurudampalayam",
      "addressRegion": "Tamil Nadu",
      "postalCode": "641017",
      "addressCountry": "IN"
    },
    "sameAs": [
      "[PLACEHOLDER — LinkedIn URL]",
      "[PLACEHOLDER — Instagram URL]"
    ]
  }
  </script>
</head>
<body class="bg-white">
  <slot />

  <script>
    // Scroll-reveal Intersection Observer
    document.addEventListener('DOMContentLoaded', () => {
      const sections = document.querySelectorAll('section');
      
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -8% 0px', // Trigger when 8% is visible from the bottom
        threshold: 0.05
      };
      
      const observer = new IntersectionObserver((entries, self) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            self.unobserve(entry.target);
          }
        });
      }, observerOptions);
      
      sections.forEach(section => {
        section.classList.add('reveal');
        
        // Trigger above-the-fold sections with a micro-delay to enable load transition (e.g. Hero Section)
        const rect = section.getBoundingClientRect();
        if (rect.top < window.innerHeight) {
          setTimeout(() => {
            section.classList.add('revealed');
          }, 50);
        } else {
          observer.observe(section);
        }
      });

      // Animated Counters Intersection Observer
      const counters = document.querySelectorAll('.animate-counter');
      
      const counterObserverOptions = {
        root: null,
        rootMargin: '0px 0px -5% 0px',
        threshold: 0.1
      };
      
      const animateCounter = (el: HTMLElement) => {
        const rawValue = el.getAttribute('data-value') || el.textContent || '';
        const match = rawValue.match(/^([^\d]*)([\d,.]+)([^\d]*)$/);
        if (!match) return;
        
        const prefix = match[1];
        const targetStr = match[2].replace(/,/g, '');
        const suffix = match[3];
        const target = parseFloat(targetStr);
        if (isNaN(target)) return;
        
        // Duration in ms
        const duration = 1500;
        
        // Default start value
        let start = 0;
        if (target > 1000) {
          start = Math.floor(target - 100);
        }
        
        const customStart = el.getAttribute('data-start');
        if (customStart !== null) {
          const parsedStart = parseFloat(customStart);
          if (!isNaN(parsedStart)) {
            start = parsedStart;
          }
        }
        
        // Ensure starting state is shown immediately before animation begins
        el.textContent = prefix + start + suffix;
        
        let startTime: number | null = null;
        
        const step = (timestamp: number) => {
          if (!startTime) startTime = timestamp;
          const progress = Math.min((timestamp - startTime) / duration, 1);
          // Easing: easeOutQuad
          const easeProgress = progress * (2 - progress);
          const currentVal = Math.floor(start + (target - start) * easeProgress);
          
          el.textContent = prefix + currentVal + suffix;
          
          if (progress < 1) {
            window.requestAnimationFrame(step);
          } else {
            // Ensure exact target is set at the end
            el.textContent = rawValue;
          }
        };
        
        window.requestAnimationFrame(step);
      };
      
      const counterObserver = new IntersectionObserver((entries, self) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateCounter(entry.target as HTMLElement);
            self.unobserve(entry.target);
          }
        });
      }, counterObserverOptions);
      
      counters.forEach(counter => {
        // Pre-set static state to start value to avoid content layout shift / flash
        const rawValue = counter.getAttribute('data-value') || counter.textContent || '';
        const match = rawValue.match(/^([^\d]*)([\d,.]+)([^\d]*)$/);
        if (match) {
          const prefix = match[1];
          const targetStr = match[2].replace(/,/g, '');
          const suffix = match[3];
          const target = parseFloat(targetStr);
          if (!isNaN(target)) {
            let start = 0;
            if (target > 1000) start = Math.floor(target - 100);
            const customStart = counter.getAttribute('data-start');
            if (customStart !== null) {
              const parsedStart = parseFloat(customStart);
              if (!isNaN(parsedStart)) start = parsedStart;
            }
            counter.textContent = prefix + start + suffix;
          }
        }
        
        counterObserver.observe(counter);
      });
    });
  </script>
</body>
</html>
