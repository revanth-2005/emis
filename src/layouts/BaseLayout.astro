---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  schema?: object;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonicalURL = Astro.url.href,
  schema,
} = Astro.props;

const siteName   = 'Ermis Global — Solar Energy Solutions';
const fullTitle  = title.includes('Ermis') ? title : `${title} | Ermis Global`;
---
<!doctype html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#C43B31" />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(image, Astro.site).toString()} />
  <meta property="og:site_name"   content={siteName} />
  <meta property="og:locale"      content="en_IN" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(image, Astro.site).toString()} />

  <!-- Favicons -->
  <link rel="icon"             type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180"      href="/apple-touch-icon.png" />

  <!-- Metropolis font is self-hosted in /public/fonts/ via global.css -->

  <!-- JSON-LD Structured Data -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Default LocalBusiness schema on every page -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Ermis Consultants & Traders Pvt Ltd",
    "alternateName": "Ermis Global",
    "url": "https://ermisglobal.com",
    "logo": "https://ermisglobal.com/logos/logo-horizontal-red.svg",
    "description": "India's trusted solar energy consultants — rooftop, commercial, and industrial solar solutions with end-to-end project delivery.",
    "telephone": "+91-98948-21309",
    "email": "ramc.ermis@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "3/73, Kurundasala Nagar, K. Vadamadurai, NGGO Colony",
      "addressLocality": "Kurudampalayam",
      "addressRegion": "Tamil Nadu",
      "postalCode": "641017",
      "addressCountry": "IN"
    },
    "sameAs": [
      "[PLACEHOLDER — LinkedIn URL]",
      "[PLACEHOLDER — Instagram URL]"
    ]
  }
  </script>
</head>
<body class="bg-white">
  <slot />

  <script>
    // Scroll-reveal Intersection Observer
    document.addEventListener('DOMContentLoaded', () => {
      const sections = document.querySelectorAll('section');
      
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -8% 0px', // Trigger when 8% is visible from the bottom
        threshold: 0.05
      };
      
      const observer = new IntersectionObserver((entries, self) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            self.unobserve(entry.target);
          }
        });
      }, observerOptions);
      
      sections.forEach(section => {
        section.classList.add('reveal');
        
        // Trigger above-the-fold sections with a micro-delay to enable load transition (e.g. Hero Section)
        const rect = section.getBoundingClientRect();
        if (rect.top < window.innerHeight) {
          setTimeout(() => {
            section.classList.add('revealed');
          }, 50);
        } else {
          observer.observe(section);
        }
      });
    });
  </script>
</body>
</html>
