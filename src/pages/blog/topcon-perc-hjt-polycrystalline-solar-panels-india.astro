        <!-- Legend -->
        <rect x="60" y="280" width="12" height="10" rx="2" fill="#9CA3AF"/>
        <text x="77" y="290" font-size="10" fill="#6B7280">Polycrystalline</text>
        <rect x="175" y="280" width="12" height="10" rx="2" fill="#C43B31" opacity="0.55"/>
        <text x="192" y="290" font-size="10" fill="#6B7280">Mono PERC</text>
