---
import PageLayout    from '../layouts/PageLayout.astro';
import Hero          from '../components/Hero.astro';
import StatsBar      from '../components/StatsBar.astro';
import ServicesGrid  from '../components/ServicesGrid.astro';
import WhySolarNow    from '../components/WhySolarNow.astro';
import Differentiators from '../components/Differentiators.astro';
import WhyChooseUs   from '../components/WhyChooseUs.astro';
import HowItWorks    from '../components/HowItWorks.astro';
import Testimonials  from '../components/Testimonials.astro';
import CTABanner     from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Ermis Global — Solar Energy Solutions for India",
  "description": "End-to-end solar energy solutions for enterprise, commercial, and residential clients across India. MNRE-aligned, ALMM-listed modules, net-metering support.",
  "url": "https://ermisglobal.com",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://ermisglobal.com"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ermisglobal.com" }]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a solar installation cost in India?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Solar installation costs in India range from ₹40,000–₹60,000 per kWp for residential systems and ₹35,000–₹55,000 per kWp for commercial/industrial systems before subsidies. Central subsidy under PM Surya Ghar can reduce costs by ₹30,000–₹78,000 for residential installations up to 3 kW."
      }
    },
    {
      "@type": "Question",
      "name": "What is PM Surya Ghar Muft Bijli Yojana?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PM Surya Ghar Muft Bijli Yojana is a central government scheme that provides subsidies for rooftop solar installations for Indian households. The scheme offers up to ₹78,000 subsidy for a 3 kW system and free electricity for the first 300 units per month."
      }
    },
    {
      "@type": "Question",
      "name": "What is the payback period for a solar system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Typical solar payback periods in India are 4–7 years for commercial rooftop systems and 6–8 years for residential installations after subsidies. After payback, the system generates free electricity for 17–21 more years."
      }
    }
  ]
};
---

<PageLayout
  title="Solar Energy Solutions for India — Ermis Global"
  description="End-to-end solar solutions for enterprise, commercial & residential clients across India. MNRE-aligned, PM Surya Ghar eligible, ALMM-listed panels. Get a free site assessment today."
  schema={schema}
>
  <!-- JSON-LD FAQ -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <Hero
    headline="Powering India's Future with Clean Solar Energy"
    subheadline="Founded by professionals with 40+ years of combined international experience. We bring global expertise and local know-how to deliver end-to-end solar solutions — from site survey to 25-year O&M."
    ctaPrimary={{ label: 'Get a Free Quote', href: '/get-a-quote' }}
    ctaSecondary={{ label: 'Our Services', href: '/services' }}
  />

  <StatsBar />

  <ServicesGrid />

  <WhySolarNow />

  <Differentiators />

  <WhyChooseUs />

  <HowItWorks />

  <!-- Savings Calculator teaser -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="section-label mb-3">Quick Estimate</p>
      <h2 class="section-heading mb-4">How Much Can You Save?</h2>
      <p class="text-neutral-muted mb-8">
        Enter your average monthly electricity bill and we'll show you an indicative system size and annual savings.
      </p>
      <div class="card flex flex-col sm:flex-row gap-4 items-end p-6 md:p-8">
        <div class="flex-1 text-left">
          <label for="bill" class="block text-sm font-medium text-neutral-ink mb-1.5">
            Monthly Electricity Bill (₹)
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-muted font-medium">₹</span>
            <input
              id="bill"
              type="number"
              min="500"
              placeholder="5,000"
              class="w-full pl-7 pr-4 py-2.5 border border-neutral-rule rounded-lg text-sm focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none"
            />
          </div>
        </div>
        <div class="text-left sm:w-36">
          <label for="segment" class="block text-sm font-medium text-neutral-ink mb-1.5">Segment</label>
          <select id="segment" class="w-full px-3 py-2.5 border border-neutral-rule rounded-lg text-sm focus:ring-2 focus:ring-brand-red outline-none">
            <option>Residential</option>
            <option>Commercial</option>
            <option>Industrial</option>
          </select>
        </div>
        <button id="calc-btn" class="btn-primary flex-shrink-0 py-2.5 text-sm">
          Calculate →
        </button>
      </div>
      <p id="calc-result" class="mt-5 text-neutral-muted text-sm hidden"></p>
      <p class="mt-3 text-xs text-neutral-muted">
        * Indicative estimate only. Actual savings depend on local tariff, sanctioned load, and roof/land availability.
        <a href="/get-a-quote" class="text-brand-red hover:underline">Get a precise analysis →</a>
      </p>
    </div>
  </section>

  <Testimonials />

  <CTABanner
    headline="Ready to Make the Switch to Solar?"
    body="Schedule a free site assessment with our engineers. Zero pressure, zero cost — just clear answers and a detailed savings estimate."
    ctaLabel="Book My Free Assessment"
    ctaHref="/get-a-quote"
    ctaSecondaryLabel="Call Us Now"
    ctaSecondaryHref="tel:+919894821309"
  />

</PageLayout>

<script>
  // Simple savings calculator
  const btn    = document.getElementById('calc-btn')!;
  const result = document.getElementById('calc-result')!;

  btn.addEventListener('click', () => {
    const bill    = parseFloat((document.getElementById('bill') as HTMLInputElement).value) || 0;
    const segment = (document.getElementById('segment') as HTMLSelectElement).value;

    if (bill < 500) {
      result.textContent = 'Please enter a monthly bill of at least ₹500.';
      result.classList.remove('hidden', 'text-neutral-muted');
      result.classList.add('text-brand-red');
      return;
    }

    // Rough estimates: tariff ₹7/kWh, 5 peak-sun-hours, panel cost ₹45/Wp
    const tariff   = segment === 'Industrial' ? 7.5 : segment === 'Commercial' ? 8 : 7;
    const units    = bill / tariff;                // monthly kWh
    const sizeKw   = Math.ceil((units / (5 * 30)) * 1.15); // kWp with 15% margin
    const annualSaving = Math.round(units * 12 * tariff * 0.85); // 85% self-consumption
    const cost     = Math.round(sizeKw * 50000); // ₹50k/kWp indicative

    result.innerHTML = `Indicative system size: <strong>${sizeKw} kWp</strong> |
      Estimated annual savings: <strong>₹${annualSaving.toLocaleString('en-IN')}</strong> |
      Approximate system cost: <strong>₹${cost.toLocaleString('en-IN')}*</strong>`;
    result.classList.remove('hidden', 'text-brand-red');
    result.classList.add('text-neutral-muted');
  });
</script>
