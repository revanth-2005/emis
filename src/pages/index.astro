---
import PageLayout    from '../layouts/PageLayout.astro';
import Hero          from '../components/Hero.astro';
import StatsBar      from '../components/StatsBar.astro';
import ServicesGrid  from '../components/ServicesGrid.astro';
import Differentiators from '../components/Differentiators.astro';
import HowItWorks    from '../components/HowItWorks.astro';
import CTABanner     from '../components/CTABanner.astro';
import ProjectGallery from '../components/ProjectGallery.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Ermis Global — Solar Energy Solutions for India",
  "description": "End-to-end solar energy solutions for enterprise, commercial, and residential clients across India. MNRE-aligned, ALMM-listed modules, net-metering support.",
  "url": "https://ermisglobal.com",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://ermisglobal.com"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://ermisglobal.com" }]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a solar installation cost in India?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Solar installation costs in India range from ₹40,000–₹60,000 per kWp for residential systems and ₹35,000–₹55,000 per kWp for commercial/industrial systems before subsidies. Central subsidy under PM Surya Ghar can reduce costs by ₹30,000–₹78,000 for residential installations up to 3 kW."
      }
    },
    {
      "@type": "Question",
      "name": "What is PM Surya Ghar Muft Bijli Yojana?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PM Surya Ghar Muft Bijli Yojana is a central government scheme that provides subsidies for rooftop solar installations for Indian households. The scheme offers up to ₹78,000 subsidy for a 3 kW system and free electricity for the first 300 units per month."
      }
    },
    {
      "@type": "Question",
      "name": "What is the payback period for a solar system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Typical solar payback periods in India are 4–7 years for commercial rooftop systems and 6–8 years for residential installations after subsidies. After payback, the system generates free electricity for 17–21 more years."
      }
    }
  ]
};
---

<PageLayout
  title="Solar Energy Solutions for India — Ermis Global"
  description="End-to-end solar solutions for enterprise, commercial & residential clients across India. MNRE-aligned, PM Surya Ghar eligible, ALMM-listed panels. Get a free site assessment today."
  schema={schema}
>
  <!-- JSON-LD FAQ -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

  <Hero
    headline="Powering India's Future with Clean Solar Energy"
    subheadline="Founded by professionals with 40+ years of combined international experience. We bring global expertise with end-to-end solar solutions"
    ctaPrimary={{ label: 'Our Services', href: '/services' }}
    ctaSecondary={{ label: 'Our works', href: '/portfolio' }}
    badge="India's Trusted Solar Partner"
  />

  <StatsBar />

  <!-- Who We Are -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left Column: Visual Image with border highlight -->
        <div class="lg:col-span-5 relative group whoweare-anim opacity-0 transform translate-y-6 transition-all duration-700 ease-out">
          <div class="absolute -inset-1 bg-gradient-to-r from-brand-red to-brand-light rounded-2xl blur opacity-10 group-hover:opacity-20 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative overflow-hidden rounded-2xl shadow-xl border border-neutral-rule/30 aspect-[4/3] sm:aspect-[16/10] lg:aspect-square">
            <img 
              src="/service_residential_hero.png" 
              alt="Clean solar panel roof setup" 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
        </div>

        <!-- Right Column: Text Content -->
        <div class="lg:col-span-7 space-y-6 whoweare-anim opacity-0 transform translate-y-6 transition-all duration-700 ease-out" style="transition-delay: 150ms;">
          <div>
            <p class="section-label mb-3">Who We Are</p>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-ink leading-tight">
              Powering a Brighter, Greener Tomorrow
            </h2>
          </div>
          
          <div class="space-y-4 text-sm sm:text-base text-neutral-muted leading-relaxed">
            <p>
              We are a trusted solar energy company committed to helping homeowners, businesses, and industries switch to clean, affordable, and sustainable power. With a focus on quality, innovation, and customer satisfaction, we deliver end-to-end solar solutions that reduce electricity costs while contributing to a greener future.
            </p>
            <p>
              From site assessment and system design to installation, subsidy assistance, net metering, and after-sales support, our experienced team ensures a seamless solar journey. We use high-performance, ALMM-approved solar modules and industry-leading components to deliver reliable systems built for long-term performance and maximum energy savings.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ServicesGrid />

  <!-- Savings Calculator teaser (Positioned below What We Do) -->
  <section id="calculator" class="py-20 bg-neutral-snow border-t border-b border-neutral-rule/65">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="section-label mb-3">Solar ROI Calculator</p>
        <h2 class="section-heading mb-4">Calculate Your Instant Savings</h2>
        <p class="text-neutral-muted max-w-2xl mx-auto text-sm sm:text-base">
          Adjust the inputs below to see your recommended solar system capacity, estimated monthly and annual bill savings, and payback period instantly.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        
        <!-- Left: Inputs -->
        <div class="lg:col-span-5 flex flex-col justify-between bg-white border border-neutral-rule rounded-2xl p-6 sm:p-8 shadow-sm">
          <div class="space-y-6">
            <!-- Monthly Bill Input & Slider -->
            <div>
              <div class="flex justify-between items-center mb-2">
                <label for="bill-range" class="text-sm font-bold text-neutral-ink">Average Monthly Bill</label>
                <div class="relative max-w-[130px]">
                  <span class="absolute left-2.5 top-1/2 -translate-y-1/2 text-neutral-muted text-xs font-semibold">₹</span>
                  <input
                    id="bill-input"
                    type="number"
                    min="500"
                    max="100000"
                    value="7500"
                    class="w-full pl-6 pr-2 py-1.5 border border-neutral-rule rounded-lg text-sm font-bold text-neutral-ink outline-none focus:ring-2 focus:ring-brand-red focus:border-brand-red"
                  />
                </div>
              </div>
              <input
                id="bill-range"
                type="range"
                min="500"
                max="50000"
                step="500"
                value="7500"
                class="w-full accent-brand-red cursor-pointer h-2 bg-neutral-rule rounded-lg appearance-none"
              />
              <div class="flex justify-between text-[10px] text-neutral-muted mt-1.5 font-semibold">
                <span>₹500</span>
                <span>₹10,000</span>
                <span>₹25,000</span>
                <span>₹50,000+</span>
              </div>
            </div>

            <!-- Segment Selector -->
            <div>
              <label for="segment" class="block text-sm font-bold text-neutral-ink mb-2">Billing Segment</label>
              <div class="relative">
                <select
                  id="segment"
                  class="w-full px-3.5 py-3 pr-10 border border-neutral-rule rounded-xl text-sm font-semibold text-neutral-ink outline-none focus:ring-2 focus:ring-brand-red bg-white appearance-none cursor-pointer"
                >
                  <option value="Residential">Residential Home</option>
                  <option value="Commercial">Commercial (Offices, Retail, Schools)</option>
                  <option value="Industrial">Industrial (Factories, Warehouses)</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-neutral-muted">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>

          <div class="pt-8 mt-6 border-t border-neutral-rule/65">
            <a href="/get-a-quote" class="btn-primary w-full justify-center py-4 text-base rounded-xl shadow-cta">
              Get Detailed Quote Proposal →
            </a>
            <p class="text-[10px] text-center text-neutral-muted mt-2">No obligation. Get custom layouts and engineering specs.</p>
          </div>
        </div>

        <!-- Right: Prominent Savings Display Panel -->
        <div class="lg:col-span-7 bg-neutral-ink rounded-2xl p-6 sm:p-8 text-white flex flex-col justify-between shadow-xl relative overflow-hidden">
          <!-- Subtle top highlight strip -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-brand-red"></div>

          <div>
            <p class="text-sm font-bold text-brand-light uppercase tracking-wider">Estimated Solar Return on Investment</p>
            
            <div class="grid grid-cols-2 gap-4 mt-6">
              <!-- Card 1: Monthly Savings -->
              <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/8 transition-colors">
                <p class="text-[10px] text-white/50 font-bold uppercase tracking-wider">Monthly Bill Savings</p>
                <p class="text-3xl sm:text-4xl font-black text-brand-light mt-1.5 tracking-tight" id="monthly-savings">₹6,375</p>
                <p class="text-[10px] text-white/40 mt-1 leading-snug">Average savings per month</p>
              </div>

              <!-- Card 2: Annual Savings -->
              <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/8 transition-colors">
                <p class="text-[10px] text-white/50 font-bold uppercase tracking-wider">Annual Cash Savings</p>
                <p class="text-3xl sm:text-4xl font-black text-white mt-1.5 tracking-tight" id="annual-savings">₹76,500</p>
                <p class="text-[10px] text-white/40 mt-1 leading-snug">Reinvestable yearly capital</p>
              </div>

              <!-- Card 3: Recommended System -->
              <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/8 transition-colors">
                <p class="text-[10px] text-white/50 font-bold uppercase tracking-wider">Recommended System</p>
                <p class="text-2xl sm:text-3xl font-black text-white mt-2 tracking-tight" id="system-size">7.8 kWp</p>
                <p class="text-[10px] text-white/40 mt-1 leading-snug" id="panel-count">Requires ~14 solar modules</p>
              </div>

              <!-- Card 4: Payback Period -->
              <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/8 transition-colors">
                <p class="text-[10px] text-white/50 font-bold uppercase tracking-wider">Est. Payback Period</p>
                <p class="text-2xl sm:text-3xl font-black text-white mt-2 tracking-tight" id="payback">4.2 Years</p>
                <p class="text-[10px] text-white/40 mt-1 leading-snug" id="payback-detail">Net payback timeline</p>
              </div>
            </div>
          </div>

          <!-- Bottom Subsidy / AD Incentive highlight message -->
          <div class="mt-8 pt-5 border-t border-white/10">
            <div class="flex gap-3 items-start bg-white/5 rounded-xl p-4 border border-white/5">
              <svg class="w-5 h-5 text-brand-light flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <div>
                <p class="text-xs font-bold text-white" id="incentive-title">PM Surya Ghar Subsidy Benefit</p>
                <p class="text-[11px] text-white/60 mt-0.5 leading-relaxed" id="incentive-desc">
                  This residential installation qualifies for a central government subsidy of ₹78,000, lowering your upfront investment.
                </p>
              </div>
            </div>
            <p class="text-[10px] text-white/40 text-center mt-3">
              * Indicative analysis. Savings depend on roof shade, utility tariffs, and actual sunshine hours.
            </p>
          </div>

        </div>

      </div>
    </div>
  </section>

  <Differentiators />

  <HowItWorks />

  <ProjectGallery />


  <CTABanner
    headline="Ready to Make the Switch to Solar?"
    body="Schedule a free site assessment with our engineers. Zero pressure, zero cost — just clear answers and a detailed savings estimate."
    ctaLabel="Book My Free Assessment"
    ctaHref="/get-a-quote"
    ctaSecondaryLabel="Call Us Now"
    ctaSecondaryHref="tel:+919894821309"
  />
</PageLayout>

<style>
  .whoweare-anim.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Whoweare entrance animations
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.whoweare-anim');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -40px 0px'
    });
    items.forEach((el) => observer.observe(el));
  });

  // ROI Calculator Calculations
  const billRange = document.getElementById('bill-range') as HTMLInputElement;
  const billInput = document.getElementById('bill-input') as HTMLInputElement;
  const segmentSelect = document.getElementById('segment') as HTMLSelectElement;

  const monthlySavingsEl = document.getElementById('monthly-savings');
  const annualSavingsEl  = document.getElementById('annual-savings');
  const systemSizeEl     = document.getElementById('system-size');
  const panelCountEl     = document.getElementById('panel-count');
  const paybackEl        = document.getElementById('payback');
  const paybackDetailEl  = document.getElementById('payback-detail');

  const incentiveTitleEl = document.getElementById('incentive-title');
  const incentiveDescEl  = document.getElementById('incentive-desc');

  function calculate() {
    if (
      !billRange || !billInput || !segmentSelect ||
      !monthlySavingsEl || !annualSavingsEl || !systemSizeEl ||
      !panelCountEl || !paybackEl || !paybackDetailEl ||
      !incentiveTitleEl || !incentiveDescEl
    ) return;

    const bill = parseFloat(billRange.value) || 0;
    const segment = segmentSelect.value;

    let tariff = 7.0; // Residential default
    let ratePerKw = 55000;

    if (segment === 'Commercial') {
      tariff = 8.5;
      ratePerKw = 52000;
    } else if (segment === 'Industrial') {
      tariff = 7.5;
      ratePerKw = 48000;
    }

    // System capacity calculation: 1 kWp generates approx 120 units/month in India
    const monthlyUnits = bill / tariff;
    const calculatedSize = monthlyUnits / 120;
    
    // Recommended size (capped at 1 decimal place, minimum 1 kWp)
    let sizeKw = Math.max(1, Math.round(calculatedSize * 10) / 10);
    
    // Panel counts: modern panels are around 550Wp each (so ~1.8 panels per kWp)
    const panelCount = Math.ceil(sizeKw * 1.8);

    // Savings: assume solar offsets 85% of grid consumption
    const monthlySavings = Math.round(bill * 0.85);
    const annualSavings = monthlySavings * 12;

    // Subsidy & Payback Calculation:
    const totalCost = sizeKw * ratePerKw;
    let subsidy = 0;
    
    if (segment === 'Residential') {
      if (sizeKw >= 3) {
        subsidy = 78000;
      } else if (sizeKw >= 2) {
        subsidy = 60000;
      } else if (sizeKw >= 1) {
        subsidy = 30000;
      }
      
      // Update incentive labels
      incentiveTitleEl.textContent = 'PM Surya Ghar Subsidy Benefit';
      incentiveDescEl.textContent = `Eligible for ₹${subsidy.toLocaleString('en-IN')} in central subsidy. Upfront net cost: ₹${(totalCost - subsidy).toLocaleString('en-IN')}.`;
      paybackDetailEl.textContent = 'Net payback timeline';
    } else {
      // Commercial/Industrial: 40% Accelerated Depreciation (AD) savings in year 1
      // Tax savings = totalCost * 40% * 25% corporate tax rate = 10% of total cost
      const taxSavings = totalCost * 0.10;
      subsidy = taxSavings; // Treated as upfront benefit
      
      incentiveTitleEl.textContent = 'Tax & Depreciation Benefits';
      incentiveDescEl.textContent = `Qualifies for 40% Accelerated Depreciation, saving approximately ₹${taxSavings.toLocaleString('en-IN')} in first-year corporate tax.`;
      paybackDetailEl.textContent = 'Payback with tax shields';
    }

    const netCost = Math.max(0, totalCost - subsidy);
    const paybackYears = Math.round((netCost / annualSavings) * 10) / 10;
    // Keep payback realistic
    const displayPayback = Math.max(3.2, Math.min(6.5, paybackYears));

    // Update DOM
    monthlySavingsEl.textContent = `₹${monthlySavings.toLocaleString('en-IN')}`;
    annualSavingsEl.textContent = `₹${annualSavings.toLocaleString('en-IN')}`;
    systemSizeEl.textContent = `${sizeKw.toFixed(1)} kWp`;
    panelCountEl.textContent = `Requires ~${panelCount} solar modules`;
    paybackEl.textContent = `${displayPayback.toFixed(1)} Years`;
  }

  // Event Listeners for real-time updates
  billRange.addEventListener('input', () => {
    billInput.value = billRange.value;
    calculate();
  });

  billInput.addEventListener('input', () => {
    // Sync slider value
    const val = parseFloat(billInput.value) || 0;
    billRange.value = String(Math.min(50000, Math.max(500, val)));
    calculate();
  });

  segmentSelect.addEventListener('change', calculate);

  // Initial load calculation
  calculate();
</script>
