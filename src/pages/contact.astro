---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact Us"
  description="Get in touch with Ermis Global — solar energy consultants across India. Call, email, or fill in the enquiry form for a prompt response."
>
  <section class="bg-neutral-ink py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-extrabold text-white mb-4">Contact Us</h1>
      <p class="text-white/70">
        For general enquiries, press, partnerships, or feedback — you're in the right place.
        If you're looking for a solar quote or site assessment, please use the
        <a href="/get-a-quote" class="text-brand-light underline underline-offset-2 hover:text-white transition-colors">Get a Free Quote</a> page instead.
      </p>
    </div>
  </section>

  <section class="py-16 bg-neutral-snow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Contact info -->
      <div class="space-y-6">
        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-pale flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13
                     a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0
                     01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-ink text-sm mb-1">Phone</h3>
              <a href="tel:+919894821309" class="text-brand-red hover:underline text-sm font-medium">
                +91 98948 21309
              </a>
              <p class="text-xs text-neutral-muted mt-0.5">
                <a href="tel:+918148221308" class="text-brand-red hover:underline">+91 81482 21308</a>
              </p>
              <p class="text-xs text-neutral-muted mt-1">Mon–Sat, 9 AM – 6 PM IST</p>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-pale flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-ink text-sm mb-1">Email</h3>
              <a href="mailto:ramc.ermis@gmail.com" class="text-brand-red hover:underline text-sm font-medium">
                ramc.ermis@gmail.com
              </a>
              <p class="text-xs text-neutral-muted mt-1">We reply within 1 business day</p>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-pale flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-ink text-sm mb-1">Head Office — Coimbatore</h3>
              <address class="not-italic text-sm text-neutral-muted leading-relaxed">
                3/73, Kurundasala Nagar,<br/>
                K. Vadamadurai, NGGO Colony,<br/>
                Kurudampalayam,<br/>
                Coimbatore – 641017,<br/>
                Tamil Nadu, India
              </address>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-brand-pale flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-ink text-sm mb-1">Branch Office — Salem</h3>
              <address class="not-italic text-sm text-neutral-muted leading-relaxed mb-2">
                Door Number : 45, Maniyakkarar Street, Attayampatti, Salem, PIN: 637501, TamilNadu
              </address>
              <a href="mailto:ramkumart.ermis@gmail.com" class="text-brand-red hover:underline text-sm font-medium block">
                ramkumart.ermis@gmail.com
              </a>
              <a href="tel:+919902257789" class="text-brand-red hover:underline text-sm font-medium">
                +91 99022 57789
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Form -->
      <div class="lg:col-span-2">
        <div class="card">
          <h2 class="text-xl font-bold text-neutral-ink mb-6">Send Us a Message</h2>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><input name="bot-field" /></p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="c-name" class="block text-sm font-medium text-neutral-ink mb-1.5">Name *</label>
                <input id="c-name" name="name" type="text" required placeholder="Your Name"
                  class="input-field" />
              </div>
              <div>
                <label for="c-email" class="block text-sm font-medium text-neutral-ink mb-1.5">Email *</label>
                <input id="c-email" name="email" type="email" required placeholder="you@email.com"
                  class="input-field" />
              </div>
            </div>

            <div>
              <label for="c-phone" class="block text-sm font-medium text-neutral-ink mb-1.5">Phone</label>
              <input id="c-phone" name="phone" type="tel" placeholder="+91 98765 43210"
                class="input-field" />
            </div>

            <div>
              <label for="c-subject" class="block text-sm font-medium text-neutral-ink mb-1.5">Subject *</label>
              <select id="c-subject" name="subject" required class="input-field">
                <option value="" disabled selected>Select a subject</option>
                <option>Existing Project / After-Sales</option>
                <option>Partnership / Vendor</option>
                <option>Media / Press</option>
                <option>Careers</option>
                <option>Other</option>
              </select>
            </div>

            <div>
              <label for="c-message" class="block text-sm font-medium text-neutral-ink mb-1.5">Message *</label>
              <textarea id="c-message" name="message" rows="5" required
                placeholder="Tell us about your requirement..."
                class="input-field resize-none"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center">
              Send Message →
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .input-field {
    @apply w-full px-4 py-2.5 border border-neutral-rule rounded-lg text-sm
           focus:ring-2 focus:ring-brand-red focus:border-brand-red outline-none
           bg-white text-neutral-ink placeholder-neutral-muted;
  }
</style>
