---
import PageLayout from '../layouts/PageLayout.astro';
import CTABanner  from '../components/CTABanner.astro';

const categories = [
  {
    name: 'Solar Panels (Modules)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    items: [
      { name: 'Monocrystalline PERC Modules', spec: '400–700 Wp, >21% efficiency, ALMM-listed', note: 'Best for space-constrained rooftops', img: '/prod_mono_perc.png' },
      { name: 'TOPCon Bifacial Modules',       spec: '500–730 Wp, >22% efficiency, bifacial gain 5–15%', note: 'Recommended for ground-mount & large rooftops', img: '/prod_topcon_bifacial.png' },
      { name: 'Polycrystalline Modules',       spec: '300–400 Wp, economy tier', note: 'Budget option for large industrial installations', img: '/prod_polycrystalline.png' },
    ],
  },
  {
    name: 'Solar Inverters',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>`,
    items: [
      { name: 'String Inverters',    spec: '3 kW – 100 kW, grid-tied', note: 'Standard choice for rooftop systems', img: '/prod_string_inverter.png' },
      { name: 'Central Inverters',   spec: '100 kW – 1000 kW, utility-scale', note: 'Large ground-mount & industrial plants', img: '/prod_central_inverter.png' },
      { name: 'Hybrid Inverters',    spec: '3 kW – 20 kW, with battery management', note: 'Homes and SMEs with backup requirement', img: '/prod_hybrid_inverter.png' },
      { name: 'Microinverters',      spec: 'Panel-level MPPT, 300–500 W each', note: 'Shaded or complex roof layouts', img: '/prod_microinverter.png' },
    ],
  },
  {
    name: 'Battery Storage',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 12h-5v5H6V7h6V2h5v10zm0 0v5a1 1 0 01-1 1H6a1 1 0 01-1-1V7a1 1 0 011-1h5V2a1 1 0 011-1h5a1 1 0 011 1v10z"/>`,
    items: [
      { name: 'Lithium Iron Phosphate (LiFePO4)', spec: '5 kWh – 1 MWh, 15-year design life', note: 'Safest chemistry for indoor installation', img: '/prod_lifepo4_battery.png' },
      { name: 'Lead-Acid (VRLA/AGM)',             spec: '2 kWh – 200 kWh', note: 'Budget backup for small systems; shorter life cycle', img: '/prod_lead_acid_battery.png' },
    ],
  },
  {
    name: 'Balance of System (BOS)',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>`,
    items: [
      { name: 'Mounting Structures',      spec: 'Hot-dip galvanised / aluminium; rooftop & ground-mount', note: 'Designed for 150 km/h wind load', img: '/prod_mounting_structure.png' },
      { name: 'DC & AC Cables',           spec: 'UV-resistant, TÜV certified', note: 'Includes junction boxes and combiners', img: '/prod_dc_ac_cables.png' },
      { name: 'Monitoring Systems',       spec: 'WiFi/GSM dataloggers, cloud platform, app integration', note: 'Real-time yield, PR, and fault alerts', img: '/prod_monitoring_system.png' },
      { name: 'Earthing & Surge Protection', spec: 'IS 3043 compliant earthing + type-1/2/3 SPDs', note: 'Mandatory for grid-connected systems', img: '/prod_surge_protection.png' },
    ],
  },
];
---

<PageLayout
  title="Solar Products — Panels, Inverters & BOS"
  description="Ermis Global sources and supplies ALMM-listed solar panels, inverters, battery storage, and BOS components from globally certified manufacturers for Indian projects."
>
  <section class="relative bg-neutral-ink py-20 overflow-hidden">
    <!-- Visual background image with overlay -->
    <div class="absolute inset-0 bg-[url('/hero_products.png')] bg-cover bg-center bg-no-repeat z-0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-neutral-ink/80 z-1" aria-hidden="true"></div>

    <div class="max-w-2xl mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl font-extrabold text-white mb-4">Solar Products We Supply</h1>
      <p class="text-white/70 leading-relaxed">
        We specify and procure only ALMM-listed, globally certified components — so your system
        performs as designed, year after year.
      </p>
    </div>
  </section>

  <section class="py-16 bg-neutral-snow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      {categories.map((cat) => (
        <div>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-lg bg-brand-pale flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={cat.icon} />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-neutral-ink">{cat.name}</h2>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {cat.items.map((item) => (
              <div class="flex flex-col bg-white rounded-2xl overflow-hidden shadow-card border border-neutral-rule/45 hover:border-brand-red/25 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 group">
                {/* Product Image top container */}
                <div class="relative h-44 w-full overflow-hidden bg-white p-4">
                  <div 
                    class="absolute inset-4 bg-contain bg-center bg-no-repeat transition-transform duration-500 ease-out group-hover:scale-105"
                    style={`background-image: url('${item.img}')`}
                  ></div>
                  <div class="absolute top-3 left-3 bg-brand-red text-white text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 rounded-md shadow-sm">
                    Premium Spec
                  </div>
                </div>
                
                {/* Details bottom container */}
                <div class="p-5 flex flex-col justify-between flex-grow">
                  <div>
                    <h3 class="font-bold text-neutral-ink text-base mb-2 group-hover:text-brand-red transition-colors duration-200">{item.name}</h3>
                    <p class="text-xs text-brand-red font-semibold mb-2">{item.spec}</p>
                  </div>
                  <p class="text-xs text-neutral-muted leading-relaxed pt-2 border-t border-neutral-rule/65">{item.note}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Vendor note -->
  <section class="py-10 bg-white border-t border-neutral-rule">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-sm text-neutral-muted">
        We work with multiple Tier-1 global and Indian manufacturers to provide best-fit products
        for each project. Specific brand recommendations are made after site assessment, based on
        availability, project requirements, and ALMM compliance. We are an independent consultant —
        not tied to any single vendor.
      </p>
    </div>
  </section>

  <CTABanner
    headline="Need a Product Specification for Your Project?"
    body="Share your project details and we'll recommend the right components with pricing."
    ctaLabel="Request a Product Specification"
    ctaHref="/get-a-quote"
  />
</PageLayout>
