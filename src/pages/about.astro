<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-hero-fade {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    will-change: transform, opacity;
  }

  /* Our Story Staggered Slide Reveals */
  .story-visual {
    opacity: 0;
    transform: translateX(-32px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .story-text {
    opacity: 0;
    transform: translateX(32px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 150ms;
    will-change: transform, opacity;
  }
  :global(section.revealed) .story-visual,
  :global(section.revealed) .story-text {
    opacity: 1;
    transform: translate(0);
  }

  /* Core Values Staggered Reveals */
  .value-card {
    opacity: 0;
    transform: translateY(24px);
    will-change: transform, opacity;
  }
  :global(section.revealed) .value-card {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(section.revealed) .value-card:nth-child(1) { transition-delay: 0ms; }
  :global(section.revealed) .value-card:nth-child(2) { transition-delay: 100ms; }
  :global(section.revealed) .value-card:nth-child(3) { transition-delay: 200ms; }
  :global(section.revealed) .value-card:nth-child(4) { transition-delay: 300ms; }

  /* Snap back instantly on hover */
  :global(section.revealed) .value-card:hover {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    transition-delay: 0ms !important;
  }

  /* Typewriter blink cursor */
  .typewriter-quote::after {
    content: '|';
    display: inline-block;
    margin-left: 2px;
    color: #cc1e1e; /* brand-red */
    opacity: 0;
  }
  .typewriter-quote.typing-active::after {
    animation: blink-cursor 0.8s infinite;
  }
  @keyframes blink-cursor {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }
</style>

<script>
  function initValuesStickyStack() {
    const cards = document.querySelectorAll('.value-card') as NodeListOf<HTMLElement>;
    const container = document.getElementById('sticky-values-stack');
    
    if (cards.length === 0 || !container) return;

    const handleScroll = () => {
      if (window.innerWidth < 768) {
        // Reset styles on mobile to prevent overlapping issues
        cards.forEach((card) => {
          card.style.transform = '';
          card.style.opacity = '';
          card.style.filter = '';
        });
        return;
      }

      cards.forEach((card, idx) => {
        const nextCard = cards[idx + 1];
        if (nextCard) {
          const nextCardRect = nextCard.getBoundingClientRect();
          // The sticky top position for the next card (must match top style: 120 + i * 24)
          const stickyThreshold = 120 + (idx + 1) * 24;
          
          if (nextCardRect.top <= stickyThreshold + 100) {
            // Next card is close or overlapping. Scale down and fade this card.
            const overlapAmount = Math.max(0, Math.min(1, (stickyThreshold + 100 - nextCardRect.top) / 200));
            const scale = 1 - overlapAmount * 0.04;
            const opacity = 1 - overlapAmount * 0.35;
            const translate = -overlapAmount * 12;
            
            card.style.transform = `scale(${scale}) translateY(${translate}px)`;
            card.style.opacity = `${opacity}`;
            card.style.filter = `blur(${overlapAmount * 0.5}px)`;
          } else {
            card.style.transform = 'scale(1) translateY(0)';
            card.style.opacity = '1';
            card.style.filter = 'none';
          }
        }
      });
    };

    window.addEventListener('scroll', handleScroll);
    window.addEventListener('resize', handleScroll);
    
    // Initial run
    handleScroll();
  }

  function initTypewriter() {
    const quoteEl = document.querySelector('.typewriter-quote') as HTMLElement;
    const authorEl = document.querySelector('.typewriter-author') as HTMLElement;
    if (!quoteEl) return;

    const fullText = quoteEl.getAttribute('data-text') || '';
    quoteEl.textContent = ''; // Clear initially

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          observer.unobserve(entry.target);
          
          // Introduce a small delay before typing starts so the screen scrolling stabilizes
          setTimeout(() => {
            quoteEl.classList.add('typing-active');
            let currentText = '';
            let i = 0;
            
            function typeChar() {
              if (i < fullText.length) {
                currentText += fullText.charAt(i);
                quoteEl.textContent = currentText;
                i++;
                setTimeout(typeChar, 18); // typing speed (18ms per character)
              } else {
                quoteEl.classList.remove('typing-active');
                if (authorEl) {
                  authorEl.classList.remove('opacity-0');
                  authorEl.classList.add('opacity-100');
                }
              }
            }
            typeChar();
          }, 400);
        }
      });
    }, { threshold: 0.15 });

    observer.observe(quoteEl);
  }

  function initOfficeMapSwitcher() {
    const cards = document.querySelectorAll('.office-tab-card');
    const iframe = document.getElementById('office-map-iframe') as HTMLIFrameElement;
    
    if (cards.length === 0 || !iframe) return;

    const maps = {
      coimbatore: "https://maps.google.com/maps?q=11.091177,76.945828&hl=en&z=15&output=embed",
      salem: "https://maps.google.com/maps?q=11.53278,78.04611(Door+Number:+45,+Maniyakkarar+Street,+Attayampatti)&hl=en&z=16&output=embed"
    };

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        // Reset active state for all tab cards
        cards.forEach((c) => {
          c.classList.remove('border-brand-red', 'shadow-md');
          c.classList.add('border-neutral-rule/60');
          
          const icon = c.querySelector('.w-10');
          if (icon) {
            icon.classList.remove('bg-brand-red', 'text-white');
            icon.classList.add('bg-brand-pale', 'text-brand-red');
          }
        });

        // Set active state for clicked card
        card.classList.add('border-brand-red', 'shadow-md');
        card.classList.remove('border-neutral-rule/60');
        
        const icon = card.querySelector('.w-10');
        if (icon) {
          icon.classList.remove('bg-brand-pale', 'text-brand-red');
          icon.classList.add('bg-brand-red', 'text-white');
        }

        // Load new map source
        const mapKey = card.getAttribute('data-target-map') as keyof typeof maps;
        if (mapKey && maps[mapKey]) {
          iframe.src = maps[mapKey];
        }
      });
    });
  }

  // Set up on page load
  document.addEventListener('DOMContentLoaded', () => {
    initValuesStickyStack();
    initTypewriter();
    initOfficeMapSwitcher();
  });
</script>
