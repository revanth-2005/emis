    name: 'Mr. Ramanadane C',
    role: 'Director',
    photo: '/director_ramanadane.png',
    bio: 'Experienced professional with extensive expertise in the textile value chain. Has worked in international locations bringing global perspectives and best practices to Ermis.',
    expertise: ['International Trade', 'Textile Industry', 'Business Development', 'Strategic Planning'],
