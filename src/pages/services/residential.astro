---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner  from '../../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Residential Solar Solutions",
  "provider": { "@type": "Organization", "name": "Ermis Consultants & Traders Pvt Ltd" },
  "description": "Rooftop solar for homes and housing societies in India. PM Surya Ghar Muft Bijli Yojana subsidy support, DISCOM net-metering, and hassle-free installation.",
  "areaServed": { "@type": "Country", "name": "India" }
};

const faq = [
  {
    q: 'How much subsidy can I get under PM Surya Ghar Yojana?',
    a: 'Under PM Surya Ghar Muft Bijli Yojana, the central government subsidy is ₹30,000/kWp for systems up to 2 kW (max ₹60,000) and ₹18,000/kWp for the 2–3 kW slab (total up to ₹78,000 for a 3 kWp system). Additional state subsidies may apply. We handle the entire portal registration and claim process.'
  },
  {
    q: 'Will my electricity bill really go to zero?',
    a: 'For households with adequate roof space and a monthly bill of ₹2,000–₹5,000, a well-sized grid-tied system can offset 80–100% of daytime consumption. Net-metering credits surplus generation, further reducing bills. Battery storage is optional for backup during outages.'
  },
  {
    q: 'How long does installation take?',
    a: 'Typically 2–5 working days for the physical installation. DISCOM approval and net-meter installation can take 2–6 weeks depending on the state. We manage all paperwork — you don\'t need to visit any office.'
  },
  {
    q: 'What is the minimum roof area needed?',
    a: 'A 1 kWp system requires approximately 80–100 sq. ft. of shadow-free roof space. A 3 kWp system (the most popular for homes) needs around 250–300 sq. ft.'
  },
  {
    q: 'Do I need a battery?',
    a: 'For a grid-tied system (the most common and cost-effective choice), no battery is required. Power cuts? We offer hybrid systems with battery backup — at higher upfront cost. We\'ll recommend what suits your electricity reliability situation.'
  },
];
---

<PageLayout
  title="Residential Solar — PM Surya Ghar Subsidy Guide"
  description="Go solar at home with Ermis Global. PM Surya Ghar Muft Bijli Yojana subsidy up to ₹78,000, hassle-free DISCOM approval, and installation in under 2 weeks. Get a free assessment."
  schema={schema}
>
  <nav class="bg-neutral-snow border-b border-neutral-rule py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-neutral-muted flex gap-2">
      <a href="/" class="hover:text-brand-red">Home</a><span>/</span>
      <a href="/services" class="hover:text-brand-red">Services</a><span>/</span>
      <span class="text-neutral-ink font-medium">Residential</span>
    </div>
  </nav>

  <section class="bg-neutral-ink py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="section-label mb-3 text-brand-light">For Your Home</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5">
          Own Your Power. Stop Paying Rising Bills.
        </h1>
        <p class="text-white/70 text-lg leading-relaxed mb-8">
          Solar for your home has never been more affordable. With PM Surya Ghar Muft Bijli
          Yojana subsidies and state incentives, a 3 kW system can cost as little as ₹70,000–80,000
          after benefits — and start saving from Day 1.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/get-a-quote" class="btn-primary">Check My Subsidy Eligibility</a>
          <a href="#faq"         class="btn-ghost">Common Questions</a>
        </div>
      </div>

      <!-- Subsidy breakdown card -->
      <div class="mt-12 lg:mt-0">
        <div class="bg-white rounded-2xl p-6">
          <h2 class="font-bold text-neutral-ink text-lg mb-4">
            PM Surya Ghar Subsidy Breakdown
          </h2>
          <div class="space-y-3 text-sm">
            {[
              { label: '1 kWp system', subsidy: '₹30,000', note: '₹30,000/kWp' },
              { label: '2 kWp system', subsidy: '₹60,000', note: '₹30,000/kWp × 2' },
              { label: '3 kWp system', subsidy: '₹78,000', note: '₹60,000 + ₹18,000 (slab 2)' },
              { label: '4 kWp+ system', subsidy: '₹78,000', note: 'Max central subsidy capped at 3 kWp' },
            ].map((row) => (
              <div class="flex items-center justify-between py-2 border-b border-neutral-rule last:border-0">
                <span class="text-neutral-ink font-medium">{row.label}</span>
                <div class="text-right">
                  <span class="text-brand-red font-bold">{row.subsidy}</span>
                  <span class="text-neutral-muted text-xs block">{row.note}</span>
                </div>
              </div>
            ))}
          </div>
          <p class="text-xs text-neutral-muted mt-4">
            * Additional state subsidies may be available. Eligibility subject to DISCOM and PM Surya Ghar portal approval.
            Our team handles the entire application process.
          </p>
          <a href="/get-a-quote" class="btn-primary w-full justify-center mt-5 text-sm">
            Check My Eligibility →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How we make it easy -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-10">We Handle Everything — You Just Enjoy the Savings</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {[
          { t: 'Free Home Assessment',        b: 'Our engineer visits your home, measures roof area, checks DISCOM connection, and designs the optimal system.' },
          { t: 'PM Surya Ghar Registration',  b: 'We register you on the national portal, submit documents, and track approval — you don\'t visit any office.' },
          { t: 'State Subsidy Applications',  b: "Many states offer additional subsidies. We identify and apply for every benefit you're entitled to." },
          { t: 'Net-Meter Application',       b: 'We file the net-metering application with your DISCOM and follow up until the bi-directional meter is installed.' },
          { t: 'Certified Installation',      b: 'Our MNRE-certified installation teams complete the physical work in 2–5 days with minimal disruption.' },
          { t: '25-Year Monitoring',          b: 'Track your system\'s daily output via a mobile app. We alert you to any underperformance and dispatch a technician.' },
        ].map((item) => (
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-brand-red text-white font-bold text-sm flex items-center justify-center flex-shrink-0 mt-0.5">✓</div>
            <div>
              <h3 class="font-semibold text-neutral-ink text-sm mb-1">{item.t}</h3>
              <p class="text-xs text-neutral-muted leading-relaxed">{item.b}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-16 bg-neutral-snow">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-10">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faq.map((item) => (
          <details class="card cursor-pointer group">
            <summary class="flex items-center justify-between font-semibold text-neutral-ink text-sm list-none">
              {item.q}
              <svg class="w-4 h-4 text-brand-red flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="mt-3 text-sm text-neutral-muted leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    headline="Check Your Home's Solar Potential"
    body="Free site visit, subsidy check, and savings estimate — zero cost, zero obligation."
    ctaLabel="Book My Free Home Assessment"
    ctaHref="/get-a-quote"
  />
</PageLayout>
