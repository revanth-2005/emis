    ctaHref="/get-a-quote"
  />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Smooth scroll for lead form anchor
      const anchorBtn = document.querySelector('a[href="#residential-lead-form"]');
      anchorBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById('residential-lead-form');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          target.classList.add('ring-2', 'ring-brand-red');
          setTimeout(() => target.classList.remove('ring-2', 'ring-brand-red'), 1500);
        }
      });

      // Lead Form submission
      const form = document.getElementById('res-form') as HTMLFormElement | null;
      const successBlock = document.getElementById('res-success');
      const errorBlock   = document.getElementById('res-error');
      const retryBtn     = document.getElementById('res-retry');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = new FormData(form);
        try {
          const response = await fetch('/api/send-lead', { method: 'POST', body: data });
          if (response.ok) {
            form.classList.add('hidden');
            successBlock?.classList.remove('hidden');
          } else {
            form.classList.add('hidden');
            errorBlock?.classList.remove('hidden');
          }
        } catch (_) {
          form.classList.add('hidden');
          errorBlock?.classList.remove('hidden');
        }
      });

      retryBtn?.addEventListener('click', () => {
        errorBlock?.classList.add('hidden');
        form?.classList.remove('hidden');
      });
    });
  </script>
</PageLayout>
