---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner  from '../../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Residential Solar Solutions",
  "provider": { "@type": "Organization", "name": "Ermis Consultants & Traders Pvt Ltd" },
  "description": "Rooftop solar for homes and housing societies in India. PM Surya Ghar Muft Bijli Yojana subsidy support, DISCOM net-metering, and hassle-free installation.",
  "areaServed": { "@type": "Country", "name": "India" }
};
---

<PageLayout
  title="Residential Solar — PM Surya Ghar Subsidy Guide"
  description="Go solar at home with Ermis Global. PM Surya Ghar Muft Bijli Yojana subsidy up to ₹78,000, hassle-free DISCOM approval, and installation in under 2 weeks. Get a free assessment."
  schema={schema}
>
  <nav class="bg-neutral-snow border-b border-neutral-rule py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-neutral-muted flex gap-2">
      <a href="/" class="hover:text-brand-red">Home</a><span>/</span>
      <a href="/services" class="hover:text-brand-red">Services</a><span>/</span>
      <span class="text-neutral-ink font-medium">Residential</span>
    </div>
  </nav>

  <!-- HERO: Keep as-is with subsidy breakdown card -->
  <section class="relative bg-neutral-ink py-20 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/solar-power-house-update.jpg')] bg-cover bg-center bg-no-repeat z-0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-neutral-ink/80 z-1" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-2 gap-16 items-center relative z-10">
      <div>
        <p class="section-label mb-3 text-brand-light">For Your Home</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5">
          Own Your Power. Stop Paying Rising Bills.
        </h1>
        <p class="text-white/70 text-lg leading-relaxed mb-8">
          Solar for your home has never been more affordable. With PM Surya Ghar Muft Bijli
          Yojana subsidies and state incentives, a 3 kW system can cost as little as ₹70,000–80,000
          after benefits — and start saving from Day 1.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/get-a-quote" class="btn-primary">Check My Subsidy Eligibility</a>
          <a href="#faq"         class="btn-ghost">Common Questions</a>
        </div>
      </div>

      <!-- Subsidy breakdown card -->
      <div class="mt-12 lg:mt-0">
        <div class="bg-white rounded-2xl p-6">
          <h2 class="font-bold text-neutral-ink text-lg mb-4">
            PM Surya Ghar Subsidy Breakdown
          </h2>
          <div class="space-y-3 text-sm">
            {[
              { label: '1 kWp system', subsidy: '₹30,000', note: '₹30,000/kWp' },
              { label: '2 kWp system', subsidy: '₹60,000', note: '₹30,000/kWp × 2' },
              { label: '3 kWp system', subsidy: '₹78,000', note: '₹60,000 + ₹18,000 (slab 2)' },
              { label: '4 kWp+ system', subsidy: '₹78,000', note: 'Max central subsidy capped at 3 kWp' },
            ].map((row) => (
              <div class="flex items-center justify-between py-2 border-b border-neutral-rule last:border-0">
                <span class="text-neutral-ink font-medium">{row.label}</span>
                <div class="text-right">
                  <span class="text-brand-red font-bold">{row.subsidy}</span>
                  <span class="text-neutral-muted text-xs block">{row.note}</span>
                </div>
              </div>
            ))}
          </div>
          <p class="text-xs text-neutral-muted mt-4">
            * Additional state subsidies may be available. Eligibility subject to DISCOM and PM Surya Ghar portal approval.
            Our team handles the entire application process.
          </p>
          <a href="/get-a-quote" class="btn-primary w-full justify-center mt-5 text-sm">
            Check My Eligibility →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: Power Your Home with Clean & Affordable Solar Energy -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-12 gap-14 items-start">

      <!-- Left: Content -->
      <div class="lg:col-span-7">
        <p class="section-label mb-3">About Our Residential Solar</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-neutral-ink mb-6">
          Power Your Home with Clean &amp; Affordable Solar Energy
        </h2>
        <p class="text-neutral-muted leading-relaxed text-base mb-8">
          Make the switch to renewable energy with a residential solar solution designed to reduce your electricity bills and increase your energy independence. We provide customized rooftop solar systems for homes, handling everything from site assessment and system design to subsidy assistance, installation, and ongoing maintenance. Using premium-quality, ALMM-approved solar panels and high-efficiency components, we deliver reliable, long-lasting systems that help homeowners enjoy significant savings while contributing to a cleaner, greener future. Whether you're installing solar for the first time or upgrading your existing system, our expert team ensures a seamless, hassle-free experience from start to finish.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 flex-wrap items-center">
          <a href="#residential-lead-form" class="btn-primary w-full sm:w-auto text-center">Get a Free Home Assessment</a>
          <div class="flex items-center gap-3">
            <span class="text-neutral-muted text-sm font-semibold">Talk to Us:</span>
            <a href="tel:+919894821309"
               class="p-2.5 rounded-full border border-neutral-rule hover:border-brand-red hover:bg-brand-pale text-neutral-muted hover:text-brand-red transition-all hover:scale-110 flex items-center justify-center"
               title="Call Us">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/>
              </svg>
            </a>
            <a href="https://wa.me/919894821309?text=Hi,%20I'm%20interested%20in%20Residential%20Solar%20solutions."
               target="_blank" rel="noopener noreferrer"
               class="p-2.5 rounded-full border border-emerald-200 hover:border-emerald-400 hover:bg-emerald-50 text-emerald-500 hover:text-emerald-600 transition-all hover:scale-110 flex items-center justify-center"
               title="Chat on WhatsApp">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.455L0 24zm6.59-4.846c1.62.962 3.238 1.443 4.958 1.444 5.393 0 9.778-4.382 9.782-9.77.002-2.611-1.015-5.066-2.868-6.92C16.61 2.054 14.15 1.037 11.533 1.037c-5.396 0-9.783 4.382-9.786 9.77-.001 1.83.485 3.615 1.41 5.22L2.14 21.84l6.096-1.599-1.589-.907zm11.303-4.7c-.29-.145-1.716-.848-1.982-.945-.266-.096-.46-.145-.653.145-.193.29-.747.945-.917 1.139-.17.194-.341.218-.632.073-.29-.145-1.226-.452-2.336-1.442-.864-.77-1.447-1.722-1.617-2.013-.17-.29-.018-.447.127-.591.13-.13.29-.34.436-.51.145-.17.193-.29.29-.485.097-.194.049-.364-.025-.51-.072-.145-.653-1.576-.894-2.158-.236-.569-.475-.491-.653-.5l-.56-.007c-.193 0-.507.073-.77.364-.266.29-1.014.992-1.014 2.42 0 1.428 1.039 2.808 1.184 3.002.145.194 2.045 3.123 4.956 4.378.692.298 1.233.477 1.656.611.696.222 1.329.19 1.83.115.558-.083 1.716-.702 1.958-1.381.242-.679.242-1.261.17-1.381-.073-.119-.266-.194-.557-.34z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Lead Form -->
      <div class="mt-12 lg:mt-0 lg:col-span-5">
        <div id="residential-lead-form" class="bg-neutral-snow border border-neutral-rule rounded-2xl p-6 shadow-card">

          <!-- Success State -->
          <div id="res-success" class="hidden flex flex-col items-center justify-center text-center py-8">
            <div class="w-14 h-14 rounded-full bg-emerald-100 text-emerald-500 flex items-center justify-center mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-neutral-ink mb-2">Request Submitted!</h3>
            <p class="text-neutral-muted text-sm max-w-xs mx-auto">Our solar expert will contact you within 1 business day with your free home assessment.</p>
          </div>

          <!-- Error State -->
          <div id="res-error" class="hidden flex flex-col items-center justify-center text-center py-8">
            <div class="w-14 h-14 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-neutral-ink mb-2">Submission Failed</h3>
            <p class="text-neutral-muted text-sm mb-4">Something went wrong. Please try again.</p>
            <button id="res-retry" class="px-5 py-2.5 bg-brand-red text-white rounded-lg text-sm font-semibold hover:bg-brand-red/90 transition-all">Try Again</button>
          </div>

          <!-- Form -->
          <form id="res-form" name="residential-home-assessment" method="POST" class="space-y-4" novalidate>
            <input type="hidden" name="form-name" value="residential-home-assessment" />
            <div>
              <h3 class="text-lg font-bold text-neutral-ink">Get a Free Home Assessment</h3>
              <p class="text-neutral-muted text-xs mt-1">Our expert will contact you within 1 business day.</p>
            </div>
            <div class="space-y-3">
              <input name="name" type="text" required placeholder="Full Name *"
                class="w-full px-3.5 py-2.5 border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all bg-white" />
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <input name="phone" type="tel" required placeholder="Mobile Number *"
                  class="w-full px-3.5 py-2.5 border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all bg-white" />
                <input name="email" type="email" required placeholder="Email Address *"
                  class="w-full px-3.5 py-2.5 border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all bg-white" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <input name="city" type="text" placeholder="City / Location"
                  class="w-full px-3.5 py-2.5 border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all bg-white" />
                <select name="capacity" required
                  class="w-full px-3.5 py-2.5 border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink text-sm outline-none transition-all bg-white">
                  <option value="" disabled selected>Required Capacity *</option>
                  <option value="1kW">1 kW</option>
                  <option value="2kW">2 kW</option>
                  <option value="3kW">3 kW</option>
                  <option value="4kW">4 kW</option>
                  <option value="5kW+">5 kW+</option>
                  <option value="Not Sure">Not Sure</option>
                </select>
              </div>
            </div>
            <button type="submit" class="w-full btn-primary justify-center font-bold text-center">
              Book Free Assessment
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Our Installation Process -->
  <section class="py-20 bg-neutral-ink relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,.15) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.15) 1px, transparent 1px); background-size: 40px 40px;" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-14">
        <p class="section-label text-brand-light mb-3">Our Installation Process</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Your Journey to Solar in 5 Simple Steps</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {[
          {
            num: '01',
            title: 'Free Home Assessment',
            body: 'We inspect your roof, analyze electricity usage, and recommend the ideal solar capacity.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`
          },
          {
            num: '02',
            title: 'Customized Proposal',
            body: 'Receive a detailed quotation including system design, estimated savings, subsidy eligibility, and installation timeline.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`
          },
          {
            num: '03',
            title: 'Documentation & Approvals',
            body: 'We handle net metering applications, subsidy documentation, and utility approvals.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`
          },
          {
            num: '04',
            title: 'Professional Installation',
            body: 'Our certified technicians install your system using premium components and perform complete quality testing.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`
          },
          {
            num: '05',
            title: 'Monitoring & Support',
            body: 'Track your energy production through smart monitoring while our team provides ongoing maintenance and technical support.',
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`
          },
        ].map((step) => (
          <div class="flex flex-col items-center text-center group">
            <div class="relative mb-5">
              <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/15 group-hover:border-brand-light/50 group-hover:bg-white/10 flex items-center justify-center transition-all duration-300 shadow-lg">
                <svg class="w-7 h-7 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={step.icon} />
                </svg>
              </div>
              <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-brand-red text-white text-xs font-black flex items-center justify-center shadow-md">{step.num}</span>
            </div>
            <h3 class="font-bold text-white text-sm mb-2 group-hover:text-brand-light transition-colors duration-200">{step.title}</h3>
            <p class="text-xs text-white/55 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/get-a-quote" class="btn-primary inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Book My Free Home Assessment
        </a>
      </div>
    </div>
  </section>

  <!-- Section 4: Why Choose Residential Solar? -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="section-label mb-3">The Smart Choice</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-neutral-ink mb-4">Why Choose Residential Solar?</h2>
        <p class="text-neutral-muted leading-relaxed">
          Switching to solar isn't just about generating electricity — it's about investing in your home's future.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 9v1m-6.938-4.5A8 8 0 1112 4"/>`, title: 'Save up to 90% on electricity bills', body: 'Dramatically cut your monthly energy bill from day one of installation.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>`, title: 'Government subsidy support', body: 'Benefit from PM Surya Ghar Muft Bijli Yojana subsidies up to ₹78,000.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`, title: 'Increase property value', body: 'Solar-equipped homes command higher resale values in the market.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`, title: 'Reliable clean energy', body: 'Generate your own electricity with dependable, certified solar panels.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`, title: 'Low maintenance costs', body: 'Solar panels have no moving parts — minimal upkeep for maximum savings.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`, title: 'Protection against rising tariffs', body: 'Lock in your energy costs and insulate your household from electricity price hikes.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>`, title: '25+ years of dependable performance', body: 'Premium panels with long-term output guarantees for decades of savings.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`, title: 'Environmentally friendly', body: 'Reduce your carbon footprint and contribute to a cleaner, greener India.' },
