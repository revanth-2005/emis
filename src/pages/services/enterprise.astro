---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner  from '../../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Enterprise & Industrial Solar Solutions",
  "provider": { "@type": "Organization", "name": "Ermis Consultants & Traders Pvt Ltd" },
  "description": "Large-scale rooftop and ground-mount solar energy solutions for factories, warehouses, and industrial plants across India. Includes captive power, open access, EPC, and O&M.",
  "areaServed": { "@type": "Country", "name": "India" }
};

const useCases = [
  {
    title: 'Manufacturing Plants',
    body: 'Reduce per-unit production cost with on-site captive solar. Claim accelerated depreciation (Section 32) in Year 1.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.25 18H20.75M4.5 18V9.25L9 6V18M9.75 18V11.25L14.25 8V18M15 18V13.25L19.5 10V18" />`
  },
  {
    title: 'Warehouses & Logistics',
    body: 'Large flat roof areas = large solar arrays = large savings. Ideal for 24x7 operations with peak daytime consumption.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`
  },
  {
    title: 'Data Centres',
    body: 'Meet sustainability mandates and reduce PUE with behind-the-meter solar + battery storage integration.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />`
  },
  {
    title: 'SEZ & Industrial Parks',
    body: 'Common area solar + open access wheeling for multiple units within a park.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 9h1.5m-1.5 3h1.5m-1.5 3h1.5m3.75-6H15m-1.25 3H15m-1.25 3H15" />`
  },
];
---

<PageLayout
  title="Enterprise & Industrial Solar Solutions"
  description="Large-scale solar for factories, warehouses, and industrial plants in India. Ground-mount, rooftop, captive power, open access, EPC & O&M. Get a free DPR from Ermis Global."
  schema={schema}
>
  <nav class="bg-neutral-snow border-b border-neutral-rule py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-neutral-muted flex gap-2">
      <a href="/" class="hover:text-brand-red">Home</a>
      <span>/</span>
      <a href="/services" class="hover:text-brand-red">Services</a>
      <span>/</span>
      <span class="text-neutral-ink font-medium">Enterprise & Industrial</span>
    </div>
  </nav>

  <section class="relative bg-neutral-ink py-20 overflow-hidden">
    <!-- Visual background image with overlay -->
    <div class="absolute inset-0 bg-[url('/service_industrial_hero.png')] bg-cover bg-center bg-no-repeat z-0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-neutral-ink/80 z-1" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-12 gap-12 items-center relative z-10">
      <div class="lg:col-span-7">
        <p class="section-label mb-3 text-brand-light">Enterprise & Industrial Solar</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 leading-tight">
          Power Your Business with High-Performance Solar Solutions
        </h1>
        <p class="text-white/70 text-lg leading-relaxed mb-8">
          We design, install, and maintain industrial and commercial solar plants ranging from 100 kW to multi-MW for long-term performance.
        </p>
        <div class="flex flex-col sm:flex-row flex-wrap gap-4 items-center">
          <a href="#dpr-form-card" class="btn-primary w-full sm:w-auto text-center">Get a Free DPR</a>
          <a href="/contact" class="btn-ghost w-full sm:w-auto text-center">Talk to Solar Expert</a>
        </div>
      </div>
      <!-- Lead Form Card -->
      <div class="mt-12 lg:mt-0 lg:col-span-5">
        <div id="dpr-form-card" class="bg-white border border-neutral-rule rounded-2xl p-6 shadow-card relative transition-all duration-300">
          
          <!-- Success State -->
          <div id="dpr-success" class="hidden flex flex-col items-center justify-center text-center py-10">
            <div class="w-14 h-14 rounded-full bg-emerald-100 text-emerald-500 flex items-center justify-center mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-neutral-ink mb-2">Request Submitted!</h3>
            <p class="text-neutral-muted text-sm max-w-xs mx-auto">
              Thank you. Our solar engineer will review your details and contact you within 1 business day with your free DPR.
            </p>
          </div>

          <!-- Error State -->
          <div id="dpr-error" class="hidden flex flex-col items-center justify-center text-center py-10">
            <div class="w-14 h-14 rounded-full bg-rose-100 text-rose-500 flex items-center justify-center mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-neutral-ink mb-2">Submission Failed</h3>
            <p class="text-neutral-muted text-sm mb-6">
              Something went wrong. Please try again.
            </p>
            <button id="dpr-error-retry" class="px-5 py-2.5 bg-brand-red text-white hover:bg-brand-red/90 rounded-lg text-sm font-semibold transition-all">
              Try Again
            </button>
          </div>

          <!-- Form Element -->
          <form
            id="dpr-form"
            name="industrial-dpr-request"
            method="POST"
            class="space-y-4"
            novalidate
          >
            <input type="hidden" name="form-name" value="industrial-dpr-request" />
            <h3 class="text-lg font-bold text-neutral-ink">Get a Free DPR & Estimate</h3>
            <p class="text-neutral-muted text-xs">Fill in your details to receive a customized techno-commercial assessment.</p>

            <div class="space-y-3.5">
              <div>
                <input id="dpr-name" name="name" type="text" required placeholder="Full Name *"
                  class="w-full px-3.5 py-2.5 bg-white border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                <div>
                  <input id="dpr-phone" name="phone" type="tel" required placeholder="Mobile Number *"
                    class="w-full px-3.5 py-2.5 bg-white border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all" />
                </div>
                <div>
                  <input id="dpr-email" name="email" type="email" required placeholder="Email Address *"
                    class="w-full px-3.5 py-2.5 bg-white border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all" />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                <div>
                  <input id="dpr-org" name="organisation" type="text" required placeholder="Company Name *"
                    class="w-full px-3.5 py-2.5 bg-white border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink placeholder-neutral-muted text-sm outline-none transition-all" />
                </div>
                <div>
                  <select id="dpr-capacity" name="capacity" required
                    class="w-full px-3.5 py-2.5 bg-white border border-neutral-rule focus:border-brand-red focus:ring-1 focus:ring-brand-red rounded-lg text-neutral-ink text-sm outline-none transition-all">
                    <option value="" disabled selected class="text-neutral-muted">Required Capacity *</option>
                    <option value="100kW-500kW">100 kW to 500 kW</option>
                    <option value="500kW-1MW">500 kW to 1 MW</option>
                    <option value="1MW-5MW">1 MW to 5 MW</option>
                    <option value="5MW+">5 MW+</option>
                    <option value="Unsure">Unsure / Need assessment</option>
                  </select>
                </div>
              </div>
            </div>

            <button type="submit" class="w-full btn-primary justify-center font-bold text-center mt-2">
              Get a Free DPR
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- What we deliver -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading mb-10 text-center">What We Deliver</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { t: 'Detailed Project Report (DPR)',     b: 'Full techno-commercial report with energy yield simulation (PVsyst), financial model, IRR, and payback analysis.' },
          { t: 'EPC — Full Turnkey Execution',      b: 'Engineering, procurement of ALMM-listed modules, inverters, and BOS; civil works; grid-tie commissioning.' },
          { t: 'Open Access & Captive Advisory',    b: 'State-specific open access routing, banking regulations, and cross-subsidy surcharge optimisation.' },
          { t: 'RESCO & BOOT Structuring',          b: 'Zero-capex models where we fund, own, and operate the plant — you pay only for consumed units at a fixed tariff.' },
          { t: 'Regulatory & DISCOM Compliance',   b: 'State commission approvals, net-metering/gross-metering selection, synchronisation reports, and metering.' },
          { t: 'O&M & Remote Monitoring',           b: 'SCADA-enabled monitoring, preventive maintenance schedules, PR (Performance Ratio) tracking, and annual reporting.' },
        ].map((item) => (
          <div class="card">
            <h3 class="font-bold text-neutral-ink mb-2">{item.t}</h3>
            <p class="text-sm text-neutral-muted leading-relaxed">{item.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The Process -->
  <section class="py-20 bg-neutral-ink relative overflow-hidden">
    <!-- subtle background grid -->
    <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,.15) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.15) 1px, transparent 1px); background-size: 40px 40px;" aria-hidden="true"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-14">
        <p class="section-label text-brand-light mb-3">How It Works</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-white">Your Solar Journey in 5 Simple Steps</h2>
      </div>

      <div class="relative">


        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
          {[
            {
              num: '01',
              title: 'Free Site Survey',
              body: 'Our solar experts inspect your property, analyze your electricity usage, and assess available roof or land space to determine the best solution.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`
            },
            {
              num: '02',
              title: 'System Design & Quotation',
              body: 'We design a customized solar system based on your energy needs and provide a detailed proposal with estimated savings, ROI, and project timeline.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`
            },
            {
              num: '03',
              title: 'Approvals & Documentation',
              body: 'We handle all necessary paperwork — subsidy applications, net metering, and utility approvals — ensuring a completely hassle-free process.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`
            },
            {
              num: '04',
              title: 'Installation & Testing',
              body: 'Our certified technicians install the solar system using premium-quality components, followed by thorough testing and commissioning.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`
            },
            {
              num: '05',
              title: 'Monitoring & After-Sales Support',
              body: 'Real-time performance monitoring, regular maintenance, and dedicated support to maximize your energy savings for years to come.',
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`
            },
          ].map((step) => (
            <div class="process-step flex flex-col items-center text-center group">
              <!-- Step circle -->
              <div class="relative mb-5">
                <div class="w-20 h-20 rounded-2xl bg-white/5 border border-white/15 group-hover:border-brand-light/50 group-hover:bg-white/10 flex items-center justify-center transition-all duration-300 shadow-lg">
                  <svg class="w-7 h-7 text-brand-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={step.icon} />
                  </svg>
                </div>
                <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-brand-red text-white text-xs font-black flex items-center justify-center shadow-md">{step.num}</span>
              </div>
              <h3 class="font-bold text-white text-sm mb-2 group-hover:text-brand-light transition-colors duration-200">{step.title}</h3>
              <p class="text-xs text-white/55 leading-relaxed">{step.body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/get-a-quote" class="btn-primary inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Get Your Free Solar Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Use cases -->
  <section class="py-16 bg-neutral-snow overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-10 reveal-item">Industries We Serve</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {useCases.map((uc, i) => (
          <div
            class="flex gap-4 card usecase-card"
            style={`transition-delay: ${i * 120}ms`}
          >
            <div class="w-10 h-10 flex-shrink-0 rounded-lg bg-brand-pale flex items-center justify-center icon-container transition-all duration-300">
              <svg class="w-5 h-5 text-brand-red transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={uc.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-neutral-ink mb-1 transition-colors duration-200">{uc.title}</h3>
              <p class="text-sm text-neutral-muted leading-relaxed">{uc.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="section-label mb-3">Got Questions?</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-neutral-ink">Frequently Asked Questions</h2>
        <p class="text-neutral-muted mt-3 text-sm">Everything you need to know about enterprise solar solutions.</p>
      </div>

      <div class="space-y-3" id="faq-list">
        {[
          {
            q: 'What is an enterprise solar power system?',
            a: 'An enterprise solar power system is a large-scale solar installation designed for businesses, factories, warehouses, commercial buildings, institutions, and industrial facilities to generate clean electricity and significantly reduce energy costs.'
          },
          {
            q: 'How much can my business save with solar?',
            a: 'Depending on your electricity consumption, system size, and location, businesses can reduce their electricity bills by 50–90% while enjoying long-term savings for over 25 years.'
          },
          {
            q: 'What industries can benefit from enterprise solar?',
            a: 'Our solutions are ideal for: Manufacturing Plants, Warehouses & Logistics Parks, Commercial Buildings, Hotels & Resorts, Hospitals, Educational Institutions, IT Parks, Shopping Malls, and Industrial Estates.'
          },
          {
            q: 'What is the minimum project size?',
            a: 'We typically undertake enterprise solar projects starting from 100 kW, with scalable solutions extending to multi-megawatt installations.'
          },
          {
            q: 'How long does installation take?',
            a: 'Most enterprise solar projects are completed within 4–12 weeks, depending on the project size, site conditions, approvals, and equipment availability.'
          },
        ].map((item, i) => (
          <details class="faq-item group border border-neutral-rule rounded-xl overflow-hidden bg-white hover:border-brand-red/30 transition-colors duration-200" >
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none select-none">
              <span class="font-semibold text-neutral-ink text-sm group-open:text-brand-red transition-colors duration-200">
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand-pale text-brand-red text-xs font-black mr-3 flex-shrink-0">{i + 1}</span>
                {item.q}
              </span>
              <svg class="w-4 h-4 text-neutral-muted group-open:text-brand-red group-open:rotate-180 transition-all duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-0">
              <div class="border-t border-neutral-rule/60 pt-4">
                <p class="text-sm text-neutral-muted leading-relaxed">{item.a}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* Use Case cards fade up entrance styling */
    .reveal-item,
    .usecase-card {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1), transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .reveal-item.visible,
    .usecase-card.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Use Case Card Hover effects */
    .usecase-card {
      position: relative;
      cursor: pointer;
      background: #ffffff;
      border: 1px solid #e5e7eb;
      transition: opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1), transform 0.65s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, border-color 0.3s ease;
    }
    
    .usecase-card:hover {
      transform: translateY(-4px) scale(1.015);
      box-shadow: 0 10px 25px -5px rgba(196, 59, 49, 0.08), 0 8px 16px -8px rgba(196, 59, 49, 0.08);
      border-color: rgba(196, 59, 49, 0.25);
    }

    .usecase-card:hover .icon-container {
      background: var(--color-brand-red, #c43b31);
    }
    
    .usecase-card:hover .icon-container svg {
      color: #ffffff;
      transform: scale(1.1) rotate(12deg);
    }

    .usecase-card:hover h3 {
      color: var(--color-brand-red, #c43b31);
    }

    /* Small red active highlight strip at the left */
    .usecase-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 25%;
      bottom: 25%;
      width: 3px;
      background: var(--color-brand-red, #c43b31);
      border-radius: 0 4px 4px 0;
      transform: scaleY(0);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .usecase-card:hover::before {
      transform: scaleY(1);
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Intersection Observer for scroll animations
      const revealItems = document.querySelectorAll('.usecase-card, .reveal-item');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });
      revealItems.forEach((el) => observer.observe(el));

      // Smooth scroll for hero anchor buttons
      const anchorBtn = document.querySelector('a[href^="#dpr-form-card"]');
      anchorBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById('dpr-form-card');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          // Highlight card momentarily
          target.classList.add('ring-2', 'ring-brand-light');
          setTimeout(() => {
            target.classList.remove('ring-2', 'ring-brand-light');
          }, 1500);
        }
      });

      // Lead Form submission handler
      const form = document.getElementById('dpr-form') as HTMLFormElement | null;
      const successBlock = document.getElementById('dpr-success');
      const errorBlock = document.getElementById('dpr-error');
      const retryBtn = document.getElementById('dpr-error-retry');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        const data = new FormData(form);
        try {
          const response = await fetch('/api/send-lead', {
            method: 'POST',
            body: data,
          });
          if (response.ok) {
            form.classList.add('hidden');
            successBlock?.classList.remove('hidden');
          } else {
            form.classList.add('hidden');
            errorBlock?.classList.remove('hidden');
          }
        } catch (_) {
          form.classList.add('hidden');
          errorBlock?.classList.remove('hidden');
        }
      });

      retryBtn?.addEventListener('click', () => {
        errorBlock?.classList.add('hidden');
        form?.classList.remove('hidden');
      });
    });
  </script>

