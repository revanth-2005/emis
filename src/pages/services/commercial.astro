---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner  from '../../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Building Solar Solutions",
  "provider": { "@type": "Organization", "name": "Ermis Consultants & Traders Pvt Ltd" },
  "description": "Rooftop solar solutions for offices, retail outlets, hotels, warehouses, schools, and hospitals in India. Subsidy guidance, net-metering, and complete EPC.",
  "areaServed": { "@type": "Country", "name": "India" }
};
---

<PageLayout
  title="Commercial Solar Solutions for Offices & Retail"
  description="Reduce operating costs with rooftop solar for offices, retail, hotels, institutions, and commercial buildings. Ermis Global handles DISCOM approvals, subsidies, and EPC across India."
  schema={schema}
>
  <nav class="bg-neutral-snow border-b border-neutral-rule py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-neutral-muted flex gap-2">
      <a href="/" class="hover:text-brand-red">Home</a><span>/</span>
      <a href="/services" class="hover:text-brand-red">Services</a><span>/</span>
      <span class="text-neutral-ink font-medium">Commercial</span>
    </div>
  </nav>

  <section class="relative bg-neutral-ink py-20 overflow-hidden">
    <!-- Visual background image with overlay -->
    <div class="absolute inset-0 bg-[url('/service_commercial_hero.png')] bg-cover bg-center bg-no-repeat z-0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-neutral-ink/80 z-1" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-2 gap-16 items-center relative z-10">
      <div>
        <p class="section-label mb-3 text-brand-light">Commercial Solar</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5">
          Cut Your Operating Costs. Green Your Brand.
        </h1>
        <p class="text-white/70 text-lg leading-relaxed mb-8">
          For offices, malls, hotels, schools, and hospitals — rooftop solar reduces electricity
          bills by 30–60%, qualifies for accelerated depreciation, and demonstrates genuine ESG
          commitment to stakeholders.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/get-a-quote" class="btn-primary">Get a Free Energy Audit</a>
          <a href="/contact"     class="btn-ghost">Talk to an Expert</a>
        </div>
      </div>
      <div class="mt-12 lg:mt-0 grid grid-cols-2 gap-4">
        {[
          { v: '10 kW+',   l: 'Minimum project size' },
          { v: '4–6 yrs',  l: 'Typical payback period' },
          { v: '40%',      l: 'Max accelerated depreciation (Year 1)' },
          { v: 'Net-meter',l: 'Export excess units to grid' },
        ].map((m) => (
          <div class="bg-white/10 border border-white/20 rounded-xl p-5 text-center">
            <p class="text-2xl font-extrabold text-white">{m.v}</p>
            <p class="text-xs text-white/60 mt-1">{m.l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12 segment-header">Commercial Segments We Serve</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Offices',             img: '/segment_offices.png',     desc: 'Power corporate headquarters, IT parks, and business centers with clean energy to cut daily AC loads.' },
          { title: 'Retail & Malls',       img: '/segment_retail.png',      desc: 'Offset peak daytime electricity usage from extensive lighting and HVAC systems on shopping center roofs.' },
          { title: 'Hotels & Resorts',     img: '/segment_hotels.png',      desc: 'Provide sustainable luxury experiences while reducing costs for hot water, pools, and guest facilities.' },
          { title: 'Hospitals',           img: '/segment_hospitals.png',   desc: 'Ensure reliable secondary energy sources for critical cooling and administrative grids.' },
          { title: 'Schools & Colleges',   img: '/segment_schools.png',     desc: 'Transform educational campus roofs into living labs and slash municipal electricity tariffs.' },
          { title: 'Warehouses',          img: '/segment_warehouses.png',  desc: 'Maximize massive flat roof profiles to lock in long-term logistics cost reductions.' },
        ].map((seg, i) => (
          <div 
            class="relative overflow-hidden rounded-2xl aspect-[4/3] sm:aspect-[1.4] shadow-card border border-neutral-rule/45 group cursor-pointer segment-card"
            style={`transition-delay: ${i * 80}ms`}
          >
            {/* Background image zoom on hover */}
            <div 
              class="absolute inset-0 bg-cover bg-center transition-transform duration-700 ease-out group-hover:scale-105 z-0"
              style={`background-image: url('${seg.img}')`}
            ></div>
            
            {/* Dark gradient overlay */}
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-ink via-neutral-ink/50 to-transparent opacity-90 transition-opacity duration-300 group-hover:opacity-95 z-10"></div>
            
            {/* Content card */}
            <div class="absolute inset-0 flex flex-col justify-end p-6 z-20">
              <h3 class="text-lg font-bold text-white mb-2 transform group-hover:translate-x-1 transition-transform duration-300 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-brand-red rounded-full"></span>
                {seg.title}
              </h3>
              <p class="text-xs text-white/80 leading-relaxed font-medium transform group-hover:translate-y-0 transition-transform duration-300">
                {seg.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* Entrance animations for segment cards */
    .segment-header,
    .segment-card {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .segment-header.visible,
    .segment-card.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('.segment-card, .segment-header');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.08,
        rootMargin: '0px 0px -40px 0px'
      });

      elements.forEach((el) => observer.observe(el));
    });
  </script>

  <!-- Incentives -->
  <section class="py-16 bg-neutral-snow">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-10">Financial Incentives You Can Claim</h2>
      <div class="space-y-4">
        {[
          { title: 'Accelerated Depreciation (Section 32)', body: '40% depreciation on the solar asset in Year 1, significantly reducing your tax liability. Effective system cost drops by ~15–20% for profitable entities.' },
          { title: 'Net-Metering',        body: 'Export surplus generation to the DISCOM grid and receive credits against your future bills. Policy varies by state — we identify the best option for your location.' },
          { title: 'Priority Sector Lending', body: 'Solar projects can qualify for priority-sector lending rates from banks and NBFCs, reducing financing costs.' },
          { title: 'MNRE Capital Subsidy', body: 'Certain commercial categories (educational institutions, hospitals) may qualify for central or state capital subsidies — we assess eligibility and file on your behalf.' },
        ].map((item) => (
          <details class="card cursor-pointer group">
            <summary class="flex items-center justify-between font-semibold text-neutral-ink text-sm list-none">
              {item.title}
              <svg class="w-4 h-4 text-brand-red flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="mt-3 text-sm text-neutral-muted leading-relaxed">{item.body}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    headline="See How Much Your Building Can Save"
    body="A free energy audit takes 30 minutes. The savings last 25 years."
    ctaLabel="Book a Free Energy Audit"
    ctaHref="/get-a-quote"
  />
</PageLayout>
