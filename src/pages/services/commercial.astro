---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner  from '../../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Building Solar Solutions",
  "provider": { "@type": "Organization", "name": "Ermis Consultants & Traders Pvt Ltd" },
  "description": "Rooftop solar solutions for offices, retail outlets, hotels, warehouses, schools, and hospitals in India. Subsidy guidance, net-metering, and complete EPC.",
  "areaServed": { "@type": "Country", "name": "India" }
};
---

<PageLayout
  title="Commercial Solar Solutions for Offices & Retail"
  description="Reduce operating costs with rooftop solar for offices, retail, hotels, institutions, and commercial buildings. Ermis Global handles DISCOM approvals, subsidies, and EPC across India."
  schema={schema}
>
  <nav class="bg-neutral-snow border-b border-neutral-rule py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-xs text-neutral-muted flex gap-2">
      <a href="/" class="hover:text-brand-red">Home</a><span>/</span>
      <a href="/services" class="hover:text-brand-red">Services</a><span>/</span>
      <span class="text-neutral-ink font-medium">Commercial</span>
    </div>
  </nav>

  <!-- Hero Banner -->
  <section class="relative bg-neutral-ink py-20 overflow-hidden">
    <div class="absolute inset-0 bg-[url('/service_commercial_hero.png')] bg-cover bg-center bg-no-repeat z-0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-neutral-ink/80 z-1" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:grid lg:grid-cols-12 gap-12 items-center relative z-10">
      <div class="lg:col-span-7">
        <p class="section-label mb-3 text-brand-light">Commercial Solar</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 leading-tight">
          Cut Your Operating Costs. Green Your Brand.
        </h1>
        <p class="text-white/70 text-lg leading-relaxed mb-8">
          For offices, malls, hotels, schools, and hospitals — rooftop solar reduces electricity
          bills by 30–60%, qualifies for accelerated depreciation, and demonstrates genuine ESG
          commitment to stakeholders.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 items-center flex-wrap">
          <a href="#commercial-lead-form" class="btn-primary w-full sm:w-auto text-center">Get a Free Energy Audit</a>
          <div class="flex items-center gap-3 w-full sm:w-auto justify-center sm:justify-start">
            <span class="text-white/60 text-sm font-semibold">Talk to an Expert:</span>
            <a href="tel:+919894821309" class="p-2.5 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-white transition-all hover:scale-110 flex items-center justify-center" title="Call Us">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 12V5z"/>
              </svg>
            </a>
            <a href="https://wa.me/919894821309?text=Hi,%20I'm%20interested%20in%20Commercial%20Solar%20solutions." target="_blank" rel="noopener noreferrer" class="p-2.5 rounded-full bg-emerald-500/20 hover:bg-emerald-500/30 border border-emerald-500/30 text-emerald-400 transition-all hover:scale-110 flex items-center justify-center" title="Chat on WhatsApp">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.455L0 24zm6.59-4.846c1.62.962 3.238 1.443 4.958 1.444 5.393 0 9.778-4.382 9.782-9.77.002-2.611-1.015-5.066-2.868-6.92C16.61 2.054 14.15 1.037 11.533 1.037c-5.396 0-9.783 4.382-9.786 9.77-.001 1.83.485 3.615 1.41 5.22L2.14 21.84l6.096-1.599-1.589-.907zm11.303-4.7c-.29-.145-1.716-.848-1.982-.945-.266-.096-.46-.145-.653.145-.193.29-.747.945-.917 1.139-.17.194-.341.218-.632.073-.29-.145-1.226-.452-2.336-1.442-.864-.77-1.447-1.722-1.617-2.013-.17-.29-.018-.447.127-.591.13-.13.29-.34.436-.51.145-.17.193-.29.29-.485.097-.194.049-.364-.025-.51-.072-.145-.653-1.576-.894-2.158-.236-.569-.475-.491-.653-.5l-.56-.007c-.193 0-.507.073-.77.364-.266.29-1.014.992-1.014 2.42 0 1.428 1.039 2.808 1.184 3.002.145.194 2.045 3.123 4.956 4.378.692.298 1.233.477 1.656.611.696.222 1.329.19 1.83.115.558-.083 1.716-.702 1.958-1.381.242-.679.242-1.261.17-1.381-.073-.119-.266-.194-.557-.34z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Lead Form -->
      <div class="mt-12 lg:mt-0 lg:col-span-5">
        <div id="commercial-lead-form" class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 shadow-2xl transition-all duration-300">

          <!-- Success State -->
          <div id="comm-success" class="hidden flex flex-col items-center justify-center text-center py-10">
            <div class="w-14 h-14 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Request Submitted!</h3>
            <p class="text-white/70 text-sm max-w-xs mx-auto">
              Thank you. Our solar engineer will contact you within 1 business day with your free energy audit.
            </p>
          </div>

          <!-- Error State -->
          <div id="comm-error" class="hidden flex flex-col items-center justify-center text-center py-10">
            <div class="w-14 h-14 rounded-full bg-rose-500/20 text-rose-400 flex items-center justify-center mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Submission Failed</h3>
            <p class="text-white/70 text-sm mb-6">Something went wrong. Please try again.</p>
            <button id="comm-error-retry" class="px-5 py-2.5 bg-white/15 hover:bg-white/25 text-white border border-white/20 rounded-lg text-sm font-semibold transition-all">
              Try Again
            </button>
          </div>

          <!-- Form -->
          <form id="comm-form" name="commercial-energy-audit" method="POST" class="space-y-4" novalidate>
            <input type="hidden" name="form-name" value="commercial-energy-audit" />
            <h3 class="text-lg font-bold text-white">Get a Free Energy Audit</h3>
            <p class="text-white/60 text-xs">Fill in your details and our expert will contact you within 1 business day.</p>

            <div class="space-y-3.5">
              <input name="name" type="text" required placeholder="Full Name *"
                class="w-full px-3.5 py-2.5 bg-white/5 border border-white/15 focus:border-brand-light focus:ring-1 focus:ring-brand-light rounded-lg text-white placeholder-white/40 text-sm outline-none transition-all" />
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                <input name="phone" type="tel" required placeholder="Mobile Number *"
                  class="w-full px-3.5 py-2.5 bg-white/5 border border-white/15 focus:border-brand-light focus:ring-1 focus:ring-brand-light rounded-lg text-white placeholder-white/40 text-sm outline-none transition-all" />
                <input name="email" type="email" required placeholder="Email Address *"
                  class="w-full px-3.5 py-2.5 bg-white/5 border border-white/15 focus:border-brand-light focus:ring-1 focus:ring-brand-light rounded-lg text-white placeholder-white/40 text-sm outline-none transition-all" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                <input name="organisation" type="text" required placeholder="Company Name *"
                  class="w-full px-3.5 py-2.5 bg-white/5 border border-white/15 focus:border-brand-light focus:ring-1 focus:ring-brand-light rounded-lg text-white placeholder-white/40 text-sm outline-none transition-all" />
                <select name="segment" required
                  class="w-full px-3.5 py-2.5 bg-white/5 border border-white/15 focus:border-brand-light focus:ring-1 focus:ring-brand-light rounded-lg text-white/90 text-sm outline-none transition-all [&>option]:bg-neutral-ink [&>option]:text-white">
                  <option value="" disabled selected>Business Type *</option>
                  <option value="Office">Office / IT Park</option>
                  <option value="Retail">Retail / Mall</option>
                  <option value="Hotel">Hotel / Resort</option>
                  <option value="Hospital">Hospital / Clinic</option>
                  <option value="School">School / College</option>
                  <option value="Warehouse">Warehouse</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>
            <button type="submit" class="w-full btn-primary justify-center font-bold text-center mt-2">
              Get a Free Energy Audit
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: Why Businesses Choose Commercial Solar -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="section-label mb-3">Why Commercial Solar</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-neutral-ink mb-5">
          Reduce Operating Costs. Increase Business Efficiency.
        </h2>
        <p class="text-neutral-muted leading-relaxed text-base">
          Commercial solar is one of the smartest investments for businesses looking to reduce electricity expenses and improve long-term profitability. By generating clean energy on-site, companies can lower their dependence on grid power, stabilize energy costs, and demonstrate a commitment to sustainability.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 9v1m-6.938-4.5A8 8 0 1112 4"/>`, title: 'Save up to 80% on electricity bills',  body: 'Dramatically reduce your monthly energy expenses and improve your bottom line from day one.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>`, title: '25+ years of reliable performance', body: 'Premium panels with long-term performance guarantees ensure decades of clean energy generation.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`, title: 'Fast ROI', body: 'Most commercial solar installations deliver full return on investment within 4–6 years.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`, title: 'Low maintenance', body: 'Solar systems have no moving parts, requiring minimal upkeep with our included O&M service.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>`, title: 'Tax benefits (where applicable)', body: 'Claim accelerated depreciation (Section 32), MNRE subsidies, and priority sector lending benefits.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`, title: 'Reduce carbon emissions', body: 'Demonstrate genuine ESG commitment to stakeholders, clients, and investors.' },
        ].map((b) => (
          <div class="card flex gap-4 items-start hover:border-brand-red/25 transition-colors duration-300">
            <div class="w-11 h-11 flex-shrink-0 rounded-xl bg-brand-pale flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={b.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-ink text-sm mb-1">{b.title}</h3>
              <p class="text-xs text-neutral-muted leading-relaxed">{b.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 2: Commercial Segments We Serve -->
  <section class="py-16 bg-neutral-snow overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-12 segment-header">Commercial Segments We Serve</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Offices',           img: '/segment_offices.png',    desc: 'Power corporate headquarters, IT parks, and business centers with clean energy to cut daily AC loads.' },
          { title: 'Retail & Malls',    img: '/segment_retail.png',     desc: 'Offset peak daytime electricity usage from extensive lighting and HVAC systems on shopping center roofs.' },
          { title: 'Hotels & Resorts',  img: '/segment_hotels.png',     desc: 'Provide sustainable luxury experiences while reducing costs for hot water, pools, and guest facilities.' },
          { title: 'Hospitals',         img: '/segment_hospitals.png',  desc: 'Ensure reliable secondary energy sources for critical cooling and administrative grids.' },
          { title: 'Schools & Colleges',img: '/segment_schools.png',    desc: 'Transform educational campus roofs into living labs and slash municipal electricity tariffs.' },
          { title: 'Warehouses',        img: '/segment_warehouses.png', desc: 'Maximize massive flat roof profiles to lock in long-term logistics cost reductions.' },
        ].map((seg, i) => (
          <div
            class="relative overflow-hidden rounded-2xl aspect-[4/3] sm:aspect-[1.4] shadow-card border border-neutral-rule/45 group cursor-pointer segment-card"
            style={`transition-delay: ${i * 80}ms`}
          >
            <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 ease-out group-hover:scale-105 z-0" style={`background-image: url('${seg.img}')`}></div>
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-ink via-neutral-ink/50 to-transparent opacity-90 transition-opacity duration-300 group-hover:opacity-95 z-10"></div>
            <div class="absolute inset-0 flex flex-col justify-end p-6 z-20">
              <h3 class="text-lg font-bold text-white mb-2 transform group-hover:translate-x-1 transition-transform duration-300 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-brand-red rounded-full"></span>
                {seg.title}
              </h3>
              <p class="text-xs text-white/80 leading-relaxed font-medium">{seg.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: Why Invest in Commercial Solar? -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="section-label mb-3">The Business Case</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-neutral-ink">Why Invest in Commercial Solar?</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {[
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 9v1m-6.938-4.5A8 8 0 1112 4"/>`, title: 'Lower Electricity Bills', body: 'Reduce monthly operating expenses significantly and free up cash flow for core business growth.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,                title: 'Better ROI',              body: 'Earn predictable savings over decades with guaranteed panel performance and low maintenance costs.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`, title: 'Sustainable Business', body: 'Meet ESG and sustainability goals, attract conscious investors, and strengthen your brand reputation.' },
          { icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,                       title: 'Energy Independence',   body: 'Reduce dependence on fluctuating utility tariffs and protect your business from rising grid costs.' },
        ].map((item) => (
          <div class="flex gap-5 p-6 rounded-2xl border border-neutral-rule hover:border-brand-red/30 hover:shadow-md transition-all duration-300 group">
            <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-brand-pale group-hover:bg-brand-red flex items-center justify-center transition-colors duration-300">
              <svg class="w-6 h-6 text-brand-red group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-neutral-ink mb-1 group-hover:text-brand-red transition-colors duration-200">{item.title}</h3>
              <p class="text-sm text-neutral-muted leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4: Financial Incentives -->
  <section class="py-16 bg-neutral-snow">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading text-center mb-10">Financial Incentives You Can Claim</h2>
      <div class="space-y-4">
        {[
          { title: 'Accelerated Depreciation (Section 32)', body: '40% depreciation on the solar asset in Year 1, significantly reducing your tax liability. Effective system cost drops by ~15–20% for profitable entities.' },
          { title: 'Net-Metering',        body: 'Export surplus generation to the DISCOM grid and receive credits against your future bills. Policy varies by state — we identify the best option for your location.' },
          { title: 'Priority Sector Lending', body: 'Solar projects can qualify for priority-sector lending rates from banks and NBFCs, reducing financing costs.' },
          { title: 'MNRE Capital Subsidy', body: 'Certain commercial categories (educational institutions, hospitals) may qualify for central or state capital subsidies — we assess eligibility and file on your behalf.' },
        ].map((item) => (
          <details class="card cursor-pointer group">
            <summary class="flex items-center justify-between font-semibold text-neutral-ink text-sm list-none">
              {item.title}
              <svg class="w-4 h-4 text-brand-red flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="mt-3 text-sm text-neutral-muted leading-relaxed">{item.body}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5: FAQ -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="section-label mb-3">Got Questions?</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-neutral-ink">Frequently Asked Questions</h2>
        <p class="text-neutral-muted mt-3 text-sm">Everything you need to know about commercial solar solutions.</p>
      </div>
      <div class="space-y-3">
        {[
          {
            q: 'What is a commercial solar power system?',
            a: 'A commercial solar power system is a photovoltaic (PV) system designed for businesses, offices, retail stores, warehouses, hotels, hospitals, educational institutions, and other commercial properties. It generates clean electricity to reduce energy costs and improve long-term sustainability.'
          },
          {
            q: 'How much can a commercial solar system reduce electricity bills?',
            a: 'A well-designed commercial solar system can reduce electricity bills by 50% to 90%, depending on your energy consumption, system size, local sunlight conditions, and utility tariffs.'
          },
          {
            q: 'Which businesses are suitable for commercial solar?',
            a: 'Commercial solar is ideal for: Office Buildings, Retail Stores, Hotels & Restaurants, Hospitals & Clinics, Schools & Colleges, Shopping Malls, Warehouses, IT Parks, and Commercial Complexes.'
          },
          {
            q: 'How do I know if my building is suitable for solar?',
            a: 'Our team conducts a free site survey to evaluate your roof size, structural strength, energy usage, shading, and available installation area before recommending the best solar solution.'
          },
          {
            q: 'What types of commercial solar systems do you offer?',
            a: 'We provide: Rooftop Solar Systems, Ground-Mounted Solar Systems, Solar Carports, Grid-Tied Solar Systems, Hybrid Solar Systems, and Battery Storage Solutions.'
          },
        ].map((item, i) => (
          <details class="group border border-neutral-rule rounded-xl overflow-hidden bg-white hover:border-brand-red/30 transition-colors duration-200">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none select-none">
              <span class="font-semibold text-neutral-ink text-sm group-open:text-brand-red transition-colors duration-200">
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-brand-pale text-brand-red text-xs font-black mr-3 flex-shrink-0">{i + 1}</span>
                {item.q}
              </span>
              <svg class="w-4 h-4 text-neutral-muted group-open:text-brand-red group-open:rotate-180 transition-all duration-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 pt-0">
              <div class="border-t border-neutral-rule/60 pt-4">
                <p class="text-sm text-neutral-muted leading-relaxed">{item.a}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    headline="See How Much Your Building Can Save"
    body="A free energy audit takes 30 minutes. The savings last 25 years."
    ctaLabel="Book a Free Energy Audit"
    ctaHref="/get-a-quote"
  />

  <style>
    .segment-header,
    .segment-card {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .segment-header.visible,
    .segment-card.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Scroll animations
      const elements = document.querySelectorAll('.segment-card, .segment-header');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      elements.forEach((el) => observer.observe(el));

      // Smooth scroll for hero CTA
      const anchorBtn = document.querySelector('a[href^="#commercial-lead-form"]');
      anchorBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById('commercial-lead-form');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          target.classList.add('ring-2', 'ring-brand-light');
          setTimeout(() => target.classList.remove('ring-2', 'ring-brand-light'), 1500);
        }
      });

      // Lead Form submission
      const form = document.getElementById('comm-form') as HTMLFormElement | null;
      const successBlock = document.getElementById('comm-success');
      const errorBlock   = document.getElementById('comm-error');
      const retryBtn     = document.getElementById('comm-error-retry');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        const data = new FormData(form);
        try {
          const response = await fetch('/api/send-lead', { method: 'POST', body: data });
          if (response.ok) {
            form.classList.add('hidden');
            successBlock?.classList.remove('hidden');
          } else {
            form.classList.add('hidden');
            errorBlock?.classList.remove('hidden');
          }
        } catch (_) {
          form.classList.add('hidden');
          errorBlock?.classList.remove('hidden');
        }
      });

      retryBtn?.addEventListener('click', () => {
        errorBlock?.classList.add('hidden');
        form?.classList.remove('hidden');
      });
    });
  </script>
</PageLayout>
